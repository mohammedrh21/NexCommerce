{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.File"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning",
        "Hangfire": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/nexcommerce-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj} <s:{SourceContext}>{NewLine}{Exception}"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "AllowedOrigins": {
    "Client": [
      "https://localhost:7001",
      "https://localhost:7156",
      "http://localhost:5029"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "",
      "Redis": "localhost:6379,abortConnect=false"
  },
  "Jwt": {
    "Issuer": "NexCommerce",
    "Audience": "NexCommerce",
    "AccessTokenMinutes": "15",
    "RefreshTokenInDays": "7",
    "Secret": "REPLACE_IN_DEV_SECRETS"
  },
  "Cloudinary": {
    "CloudName": "REPLACE_IN_DEV_SECRETS",
    "ApiKey": "REPLACE_IN_DEV_SECRETS",
    "ApiSecret": "REPLACE_IN_DEV_SECRETS"
  },
  "Email": {
    "Host": "smtp.gmail.com",
    "Port": "587",
    "FromName": "NexCommerce",
    "FromAddress": "REPLACE_IN_DEV_SECRETS",
    "Username": "REPLACE_IN_DEV_SECRETS",
    "Password": "REPLACE_IN_DEV_SECRETS"
  },
  "AutoMapper": {
    "LicenseKey": "REPLACE_IN_DEV_SECRETS"
  }
}