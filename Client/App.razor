<CascadingAuthenticationState>
    <Fluxor.Blazor.Web.StoreInitializer />

    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    @if (context.User.Identity?.IsAuthenticated == true)
                    {
                        <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
                            <h2 class="text-2xl font-bold text-slate-800 dark:text-white">Access Denied</h2>
                            <p class="mt-2 text-slate-600 dark:text-slate-400">You do not have permission to access this resource.</p>
                            <a href="/" class="mt-6 px-4 py-2 bg-brand-600 text-white rounded-lg hover:bg-brand-700 transition-colors">Go Home</a>
                        </div>
                    }
                    else
                    {
                        <RedirectToLogin />
                    }
                </NotAuthorized>
            </AuthorizeRouteView>
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            <PageTitle>Not Found</PageTitle>
            <LayoutView DefaultLayout="@typeof(MainLayout)">
                <div class="flex flex-col items-center justify-center min-h-[60vh] text-center px-4">
                    <h2 class="text-4xl font-extrabold text-brand-600">404</h2>
                    <h3 class="mt-2 text-xl font-bold text-slate-800 dark:text-white">Page Not Found</h3>
                    <p class="mt-2 text-slate-600 dark:text-slate-400">The page you are looking for does not exist or has been moved.</p>
                    <a href="/" class="mt-6 px-4 py-2 bg-brand-600 text-white rounded-lg hover:bg-brand-700 transition-colors">Back to Home</a>
                </div>
            </LayoutView>
        </NotFound>
    </Router>
</CascadingAuthenticationState>
