@namespace Client.Components.Layout
@inject NavigationManager Navigation

<footer class="bg-zinc-50 dark:bg-zinc-950 border-t border-zinc-200 dark:border-zinc-800 transition-colors duration-200">
    <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
            
            <!-- Branding -->
            <div class="space-y-4">
                <div class="flex items-center gap-2">
                    <span class="bg-indigo-650 text-white rounded-lg p-1.5 flex items-center justify-center">
                        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                        </svg>
                    </span>
                    <span class="text-lg font-bold tracking-tight text-zinc-900 dark:text-white">
                        NexCommerce
                    </span>
                </div>
                <p class="text-sm text-zinc-500 dark:text-zinc-400">
                    A premium multi-vendor e-commerce platform offering state-of-the-art SaaS seller tools and a high-speed customer shopping experience.
                </p>
                <div class="flex space-x-4">
                    <!-- Social icons placeholders with SVGs -->
                    <a href="#" class="text-zinc-400 hover:text-zinc-550 dark:hover:text-zinc-350 transition-colors">
                        <span class="sr-only">Facebook</span>
                        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z" clip-rule="evenodd" /></svg>
                    </a>
                    <a href="#" class="text-zinc-400 hover:text-zinc-550 dark:hover:text-zinc-350 transition-colors">
                        <span class="sr-only">Instagram</span>
                        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path fill-rule="evenodd" d="M12.315 2c2.43 0 2.784.008 3.81.055.97.044 1.5.206 1.85.342.463.18.792.395 1.14.743.348.349.562.678.742 1.14.136.35.298.88.342 1.85.047 1.026.055 1.38.055 3.81s-.008 2.784-.055 3.81c-.044.97-.206 1.5-.342 1.85-.18.463-.395.792-.743 1.14-.349.348-.678.562-1.14.742-.35.136-.88.298-1.85.342-1.026.047-1.38.055-3.81.055s-2.784-.008-3.81-.055c-.97-.044-1.5-.206-1.85-.342a3.004 3.004 0 01-1.14-.743 3.004 3.004 0 01-.742-1.14c-.136-.35-.298-.88-.342-1.85C2.008 14.784 2 14.43 2 12c0-2.43.008-2.784.055-3.81.044-.97.206-1.5.342-1.85.18-.463.395-.792.743-1.14.349-.348.678-.562 1.14-.742.35-.136.88-.298 1.85-.342 1.026-.047 1.38-.055 3.81-.055zm0 1.902c-2.385 0-2.668.009-3.606.052-.868.04-1.34.185-1.654.307-.417.162-.714.355-.1.027.697-.311.343-.504.56-.665.742-.162.308-.307.783-.307.786-.042.937-.052 1.22-.052 3.606 0 2.385.009 2.668.052 3.606.04.868.185 1.34.307 1.654.162.417.355.714.665.1.027.697.311.343.504.56.665.742.162.308.307.783.307.786.042.937.052 1.22.052 3.606 0-2.385-.009-2.668-.052-3.606-.04-.868-.185-1.34-.307-1.654a3.004 3.004 0 01-.665-1.027c-.311-.697-.504-.343-.665-.56-.162-.742-.307-1.62-.307-1.623.042-.937.052-1.22.052-3.606zm0 2.946a5.15 5.15 0 100 10.3 5.15 5.15 0 000-10.3zm0 8.397a3.248 3.248 0 110-6.495 3.248 3.248 0 010 6.495zm6.487-8.358a1.25 1.25 0 11-2.5 0 1.25 1.25 0 012.5 0z" clip-rule="evenodd" /></svg>
                    </a>
                    <a href="#" class="text-zinc-400 hover:text-zinc-550 dark:hover:text-zinc-350 transition-colors">
                        <span class="sr-only">Twitter</span>
                        <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24"><path d="M8.29 20.251c7.547 0 11.675-6.253 11.675-11.675 0-.178 0-.355-.012-.53A8.348 8.348 0 0022 5.92a8.19 8.19 0 01-2.357.646 4.118 4.118 0 001.804-2.27 8.224 8.224 0 01-2.605.996 4.107 4.107 0 00-6.993 3.743 11.65 11.65 0 01-8.457-4.287 4.106 4.106 0 001.27 5.477A4.072 4.072 0 012.8 9.713v.052a4.105 4.105 0 003.292 4.022 4.095 4.095 0 01-1.853.07 4.108 4.108 0 003.834 2.85A8.233 8.233 0 012 18.407a11.616 11.616 0 006.29 1.84" /></svg>
                    </a>
                </div>
            </div>

            <!-- Shop Links -->
            <div>
                <h3 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 tracking-wider uppercase">Shop</h3>
                <ul role="list" class="mt-4 space-y-2">
                    <li><a href="/products" class="text-sm text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-200 transition-colors">All Products</a></li>
                    <li><a href="/vendors" class="text-sm text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-200 transition-colors">Featured Vendors</a></li>
                    <li><a href="/cart" class="text-sm text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-200 transition-colors">Shopping Cart</a></li>
                </ul>
            </div>

            <!-- Legal/Help Links -->
            <div>
                <h3 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 tracking-wider uppercase">Help & Legal</h3>
                <ul role="list" class="mt-4 space-y-2">
                    <li><a href="#" class="text-sm text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-200 transition-colors">Contact Support</a></li>
                    <li><a href="#" class="text-sm text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-200 transition-colors">Terms of Service</a></li>
                    <li><a href="#" class="text-sm text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-200 transition-colors">Privacy Policy</a></li>
                </ul>
            </div>

            <!-- Contact/Localization -->
            <div>
                <h3 class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 tracking-wider uppercase">Language</h3>
                <p class="mt-4 text-sm text-zinc-500 dark:text-zinc-400 mb-4">
                    Switch between English and Arabic translations.
                </p>
                <div class="flex gap-2">
                    <!-- Temporary UI buttons until localization is implemented in Phase 11 -->
                    <button type="button" 
                            class="px-3 py-1.5 text-xs font-semibold rounded-lg bg-zinc-200 hover:bg-zinc-300 dark:bg-zinc-800 dark:hover:bg-zinc-700 text-zinc-800 dark:text-zinc-200 transition-colors border border-transparent shadow-sm">
                        English (EN)
                    </button>
                    <button type="button" 
                            class="px-3 py-1.5 text-xs font-semibold rounded-lg bg-zinc-200 hover:bg-zinc-300 dark:bg-zinc-800 dark:hover:bg-zinc-700 text-zinc-800 dark:text-zinc-200 transition-colors border border-transparent shadow-sm">
                        العربية (AR)
                    </button>
                </div>
            </div>
        </div>

        <div class="mt-12 border-t border-zinc-200 dark:border-zinc-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
            <p class="text-xs text-zinc-400 dark:text-zinc-500">
                &copy; @DateTime.UtcNow.Year NexCommerce. All rights reserved. Built with .NET 10 & TailwindCSS.
            </p>
            <div class="flex items-center gap-4">
                <span class="text-xs text-zinc-400 dark:text-zinc-500 flex items-center gap-1">
                    <span class="h-2 w-2 rounded-full bg-emerald-500 inline-block animate-pulse"></span>
                    API Connected
                </span>
            </div>
        </div>
    </div>
</footer>
