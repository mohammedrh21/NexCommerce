@namespace Client.Components.Layout

<header class="sticky top-0 z-40 w-full border-b border-zinc-200 dark:border-zinc-800 bg-white/80 dark:bg-zinc-900/80 backdrop-blur-md transition-colors duration-200">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <div class="flex h-16 items-center justify-between gap-4">
            
            <!-- Logo Section -->
            <div class="flex items-center gap-6">
                <a href="/" class="flex items-center gap-2" @onclick="CloseMenus">
                    <span class="bg-indigo-600 text-white rounded-lg p-1.5 shadow-md shadow-indigo-600/20 flex items-center justify-center">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                        </svg>
                    </span>
                    <span class="text-xl font-extrabold tracking-tight bg-gradient-to-r from-zinc-900 to-indigo-600 dark:from-white dark:to-indigo-400 bg-clip-text text-transparent">
                        NexCommerce
                    </span>
                </a>

                <!-- Categories Mega Menu Trigger (Desktop) -->
                <div class="relative hidden md:block">
                    <button type="button" 
                            class="inline-flex items-center gap-1.5 text-sm font-medium text-zinc-650 hover:text-zinc-900 dark:text-zinc-300 dark:hover:text-zinc-100 transition-colors focus:outline-none"
                            @onclick="ToggleCategoriesMenu"
                            @onclick:stopPropagation>
                        Categories
                        <svg class="h-4 w-4 transition-transform duration-200 @(_showCategoriesMenu ? "rotate-180" : "")" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                        </svg>
                    </button>

                    <!-- Categories Dropdown -->
                    @if (_showCategoriesMenu)
                    {
                        <div class="absolute left-0 mt-3 w-56 origin-top-left rounded-xl bg-white dark:bg-zinc-900 p-2 shadow-xl ring-1 ring-black/5 dark:ring-white/10 z-50 divide-y divide-zinc-150 dark:divide-zinc-800">
                            @if (_categories == null || !_categories.Any())
                            {
                                <div class="px-4 py-3 text-xs text-zinc-500 dark:text-zinc-400">Loading categories...</div>
                            }
                            else
                            {
                                <div class="py-1">
                                    @foreach (var category in _categories)
                                    {
                                        <button type="button" 
                                                class="w-full text-left px-4 py-2 text-sm text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/60 hover:text-indigo-600 dark:hover:text-indigo-400 rounded-lg transition-all"
                                                @onclick="() => NavigateToCategory(category.Id)">
                                            @category.Name
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- Search Bar (Desktop) -->
            <div class="flex-1 max-w-md hidden md:block">
                <div class="relative">
                    <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-zinc-400 dark:text-zinc-500">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                        </svg>
                    </div>
                    <input type="text"
                           class="w-full bg-zinc-100 dark:bg-zinc-800 border-0 pl-10 pr-4 py-1.5 text-sm rounded-full text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-455 dark:placeholder:text-zinc-500 ring-1 ring-transparent focus:ring-2 focus:ring-indigo-650 focus:bg-white dark:focus:bg-zinc-900 transition-all duration-200 focus:outline-none"
                           placeholder="Search products, brands..."
                           @bind="_searchQuery"
                           @onkeydown="HandleSearchKeyDown" />
                </div>
            </div>

            <!-- User Actions & Cart Section -->
            <div class="flex items-center gap-2 sm:gap-4">
                
                <!-- Cart Icon Button -->
                <a href="/cart" 
                   class="relative rounded-full p-2 text-zinc-650 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors focus:outline-none"
                   @onclick="CloseMenus">
                    <span class="sr-only">Cart</span>
                    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 00-3 3h15.75m-12.75-3h11.218c1.121-2.3 2.1-4.684 2.924-7.138a60.114 60.114 0 00-16.536-1.84M7.5 14.25L5.106 5.272M6 20.25a.75.75 0 11-1.5 0 .75.75 0 011.5 0zm12.75 0a.75.75 0 11-1.5 0 .75.75 0 011.5 0z" />
                    </svg>
                    @if (_cartItemCount > 0)
                    {
                        <span class="absolute -top-0.5 -right-0.5 inline-flex items-center justify-center rounded-full bg-indigo-600 px-2 py-0.5 text-xs font-semibold text-white">
                            @_cartItemCount
                        </span>
                    }
                </a>

                <!-- Notification Bell Component -->
                <NotificationBell />

                <!-- Profile Dropdown -->
                @if (_isAuthenticated)
                {
                    <div class="relative">
                        <button type="button" 
                                class="flex rounded-full bg-zinc-100 dark:bg-zinc-800 p-1 hover:ring-2 hover:ring-indigo-600 transition-all focus:outline-none"
                                @onclick="ToggleUserMenu"
                                @onclick:stopPropagation>
                            <span class="sr-only">Open user menu</span>
                            <div class="h-8 w-8 rounded-full bg-gradient-to-tr from-indigo-550 to-purple-550 flex items-center justify-center text-white font-bold text-sm select-none shadow-inner">
                                @(string.IsNullOrEmpty(_userName) ? "U" : _userName.Substring(0, 1).ToUpper())
                            </div>
                        </button>

                        @if (_showUserMenu)
                        {
                            <div class="absolute right-0 mt-3 w-56 origin-top-right rounded-xl bg-white dark:bg-zinc-900 p-2 shadow-xl ring-1 ring-black/5 dark:ring-white/10 z-50 divide-y divide-zinc-150 dark:divide-zinc-800 overflow-hidden transform transition-all duration-200">
                                <div class="px-4 py-2.5">
                                    <p class="text-sm font-semibold text-zinc-900 dark:text-zinc-100">@_userName</p>
                                    <p class="text-xs text-zinc-500 truncate dark:text-zinc-400">@_userEmail</p>
                                    @if (!string.IsNullOrEmpty(_userRole))
                                    {
                                        <span class="inline-flex items-center rounded-md bg-indigo-50 dark:bg-indigo-950/40 px-2 py-0.5 text-[10px] font-medium text-indigo-700 dark:text-indigo-405 mt-1">
                                            @_userRole
                                        </span>
                                    }
                                </div>
                                <div class="py-1">
                                    <a href="/profile" class="block px-4 py-2 text-sm text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/60 rounded-lg transition-all" @onclick="CloseMenus">
                                        Your Profile
                                    </a>
                                    
                                    @if (_userRole == "Admin")
                                    {
                                        <a href="/admin" class="block px-4 py-2 text-sm text-indigo-650 dark:text-indigo-400 font-semibold hover:bg-zinc-50 dark:hover:bg-zinc-800/60 rounded-lg transition-all" @onclick="CloseMenus">
                                            Admin Dashboard
                                        </a>
                                    }
                                    else if (_userRole == "Vendor")
                                    {
                                        <a href="/vendor" class="block px-4 py-2 text-sm text-indigo-650 dark:text-indigo-400 font-semibold hover:bg-zinc-50 dark:hover:bg-zinc-800/60 rounded-lg transition-all" @onclick="CloseMenus">
                                            Vendor Dashboard
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="/orders" class="block px-4 py-2 text-sm text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/60 rounded-lg transition-all" @onclick="CloseMenus">
                                            My Orders
                                        </a>
                                        <a href="/wishlist" class="block px-4 py-2 text-sm text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800/60 rounded-lg transition-all" @onclick="CloseMenus">
                                            Wishlist
                                        </a>
                                    }
                                </div>
                                <div class="py-1">
                                    <a href="/logout" class="block px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-950/20 rounded-lg transition-all font-medium" @onclick="CloseMenus">
                                        Sign out
                                    </a>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <a href="/login" class="text-sm font-semibold text-zinc-900 dark:text-zinc-100 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors hidden sm:block" @onclick="CloseMenus">
                        Sign in
                    </a>
                    <a href="/register" class="rounded-full bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold px-4 py-2 shadow-sm transition-all focus:outline-none focus:ring-2 focus:ring-indigo-500" @onclick="CloseMenus">
                        Get Started
                    </a>
                }

                <!-- Mobile Menu Button -->
                <button type="button" 
                        class="rounded-full p-2 text-zinc-650 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors focus:outline-none md:hidden"
                        @onclick="ToggleMobileMenu">
                    <span class="sr-only">Open menu</span>
                    @if (_showMobileMenu)
                    {
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                    }
                    else
                    {
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
                        </svg>
                    }
                </button>
            </div>
        </div>
    </div>

    <!-- Mobile Menu -->
    @if (_showMobileMenu)
    {
        <div class="md:hidden border-t border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 py-3 px-4 space-y-3 shadow-inner max-h-[85vh] overflow-y-auto">
            
            <!-- Mobile Search -->
            <div class="relative w-full">
                <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-zinc-400">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                    </svg>
                </div>
                <input type="text"
                       class="w-full bg-zinc-100 dark:bg-zinc-800 border-0 pl-10 pr-4 py-2 text-sm rounded-full text-zinc-900 dark:text-zinc-100 placeholder:text-zinc-455 focus:ring-2 focus:ring-indigo-650 focus:bg-white transition-all duration-200 focus:outline-none"
                       placeholder="Search products, brands..."
                       @bind="_searchQuery"
                       @onkeydown="HandleSearchKeyDown" />
            </div>

            <!-- Categories Section -->
            <div class="space-y-1">
                <h4 class="text-xs font-semibold text-zinc-400 dark:text-zinc-500 uppercase tracking-wider px-2">Categories</h4>
                @if (_categories == null || !_categories.Any())
                {
                    <p class="text-xs text-zinc-500 px-2">Loading...</p>
                }
                else
                {
                    @foreach (var category in _categories)
                    {
                        <button type="button" 
                                class="w-full text-left px-2 py-2 text-sm text-zinc-750 dark:text-zinc-350 hover:bg-zinc-50 dark:hover:bg-zinc-800/50 hover:text-indigo-650 rounded-lg transition-all"
                                @onclick="() => NavigateToCategory(category.Id)">
                            @category.Name
                        </button>
                    }
                }
            </div>

            <!-- Mobile Auth Links -->
            @if (!_isAuthenticated)
            {
                <div class="border-t border-zinc-100 dark:border-zinc-800 pt-3 flex flex-col gap-2">
                    <a href="/login" class="flex justify-center items-center py-2 text-sm font-semibold text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-800 rounded-lg" @onclick="CloseMenus">
                        Sign in
                    </a>
                </div>
            }
        </div>
    }
</header>

@if (_showCategoriesMenu || _showUserMenu)
{
    <!-- Click backdrop to close menus -->
    <div class="fixed inset-0 z-30" @onclick="CloseMenus"></div>
}
