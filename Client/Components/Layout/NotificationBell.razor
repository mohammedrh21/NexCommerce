@namespace Client.Components.Layout

@if (_isAuthenticated)
{
    <div class="relative">
        <!-- Bell Trigger Button -->
        <button type="button" 
                class="relative rounded-full p-2 text-zinc-650 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-zinc-100 hover:bg-zinc-100 dark:hover:bg-zinc-800 transition-colors focus:outline-none"
                @onclick="ToggleDropdown"
                @onclick:stopPropagation>
            <span class="sr-only">View notifications</span>
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
            </svg>
            
            @if (_unreadCount > 0)
            {
                <span class="absolute top-1 right-1 flex h-4 w-4">
                    <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-red-400 opacity-75"></span>
                    <span class="relative inline-flex rounded-full h-4 w-4 bg-red-500 text-[10px] font-bold text-white items-center justify-center">
                        @(_unreadCount > 9 ? "9+" : _unreadCount.ToString())
                    </span>
                </span>
            }
        </button>

        <!-- Dropdown Menu -->
        @if (_isOpen)
        {
            <div class="absolute right-0 mt-2 w-80 md:w-96 origin-top-right rounded-xl bg-white dark:bg-zinc-900 shadow-xl ring-1 ring-black/5 dark:ring-white/10 focus:outline-none z-50 divide-y divide-zinc-100 dark:divide-zinc-800 overflow-hidden transform transition-all duration-200">
                <!-- Header -->
                <div class="px-4 py-3 flex items-center justify-between">
                    <h3 class="text-sm font-semibold text-zinc-900 dark:text-zinc-150">Notifications</h3>
                    @if (_unreadCount > 0)
                    {
                        <button type="button" 
                                class="text-xs font-medium text-indigo-650 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-350 transition-colors"
                                @onclick="MarkAllAsRead">
                            Mark all as read
                        </button>
                    }
                </div>

                <!-- Notifications List -->
                <div class="max-h-72 overflow-y-auto divide-y divide-zinc-50 dark:divide-zinc-800/50">
                    @if (_notifications == null || !_notifications.Any())
                    {
                        <div class="px-4 py-8 text-center">
                            <svg class="mx-auto h-8 w-8 text-zinc-400 dark:text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" />
                            </svg>
                            <p class="mt-2 text-xs font-medium text-zinc-500 dark:text-zinc-400">No notifications yet</p>
                        </div>
                    }
                    else
                    {
                        @foreach (var notification in _notifications)
                        {
                            <button type="button" 
                                    class="w-full text-left px-4 py-3 hover:bg-zinc-50 dark:hover:bg-zinc-800/40 transition-colors flex gap-3 items-start select-none relative @(!notification.IsRead ? "bg-indigo-50/30 dark:bg-indigo-950/10" : "")"
                                    @onclick="() => HandleNotificationClick(notification)">
                                
                                <!-- Unread dot indicator -->
                                @if (!notification.IsRead)
                                {
                                    <span class="absolute left-1.5 top-4.5 h-1.5 w-1.5 rounded-full bg-indigo-600 dark:bg-indigo-400"></span>
                                }

                                <!-- Icon type based -->
                                <div class="flex-shrink-0 mt-0.5">
                                    @if (notification.Type == Models.Common.NotificationType.OrderUpdate)
                                    {
                                        <div class="h-8 w-8 rounded-full bg-blue-100 dark:bg-blue-950/50 flex items-center justify-center text-blue-600 dark:text-blue-450">
                                            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 10.5V6a3.75 3.75 0 10-75 0v4.5m11.356-1.993l1.263 12c.07.665-.45 1.243-1.119 1.243H4.25a1.125 1.125 0 01-1.12-1.243l1.264-12A1.125 1.125 0 015.513 7.5h12.974c.576 0 1.059.435 1.119 1.007zM8.625 10.5a.375.375 0 11-.75 0 .375.375 0 01.75 0zm7.5 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                                            </svg>
                                        </div>
                                    }
                                    else if (notification.Type == Models.Common.NotificationType.LowStock)
                                    {
                                        <div class="h-8 w-8 rounded-full bg-amber-100 dark:bg-amber-950/50 flex items-center justify-center text-amber-600 dark:text-amber-450">
                                            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
                                            </svg>
                                        </div>
                                    }
                                    else if (notification.Type == Models.Common.NotificationType.Chat)
                                    {
                                        <div class="h-8 w-8 rounded-full bg-emerald-100 dark:bg-emerald-950/50 flex items-center justify-center text-emerald-600 dark:text-emerald-450">
                                            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 18a5.974 5.974 0 01-.225-2.28 9.764 9.764 0 01-1.002-3.72C4.183 7.444 8.213 3.75 13.18 3.75c4.97 0 9 3.694 9 8.25z" />
                                            </svg>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="h-8 w-8 rounded-full bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center text-zinc-650 dark:text-zinc-350">
                                            <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M11.25 11.25l.041-.02a.75.75 0 111.083 1.083l-.02.041a.75.75 0 11-1.083-1.083zM12 21a9 9 0 100-18 9 9 0 000 18z" />
                                            </svg>
                                        </div>
                                    }
                                </div>

                                <!-- Message Body -->
                                <div class="flex-1 min-w-0">
                                    <p class="text-xs text-zinc-800 dark:text-zinc-200 font-medium line-clamp-2">
                                        @notification.Message
                                    </p>
                                    <p class="text-[10px] text-zinc-400 dark:text-zinc-500 mt-1">
                                        @notification.CreatedAt.ToLocalTime().ToString("g")
                                    </p>
                                </div>
                            </button>
                        }
                    }
                </div>

                <!-- Footer -->
                <div class="px-4 py-2 text-center bg-zinc-50 dark:bg-zinc-900/50">
                    <button type="button" 
                            class="text-xs font-semibold text-indigo-650 hover:text-indigo-500 dark:text-indigo-400 dark:hover:text-indigo-350 transition-colors"
                            @onclick="ViewAll">
                        View all notifications
                    </button>
                </div>
            </div>
        }
    </div>
}
