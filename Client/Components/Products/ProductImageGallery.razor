@using Client.Models.Products
@namespace Client.Components.Products

<div class="flex flex-col gap-4 @Class">
    <!-- Main Image -->
    <div class="relative overflow-hidden rounded-xl border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 aspect-w-4 aspect-h-3 sm:aspect-w-1 sm:aspect-h-1 flex items-center justify-center min-h-[300px] sm:min-h-[400px]">
        @if (!string.IsNullOrEmpty(ActiveImageUrl))
        {
            <img src="@ActiveImageUrl" 
                 alt="Product Main Image" 
                 class="w-full h-full object-contain max-h-[400px] transition-all duration-300 transform hover:scale-105" />
        }
        else
        {
            <div class="text-zinc-400 dark:text-zinc-500">
                <svg class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 15.75l5.159-5.159a2.25 2.25 0 013.182 0l5.159 5.159m-1.5-1.5l1.409-1.409a2.25 2.25 0 013.182 0l2.909 2.909m-18 3.75h16.5a1.5 1.5 0 001.5-1.5V6a1.5 1.5 0 00-1.5-1.5H3.75A1.5 1.5 0 002.25 6v12a1.5 1.5 0 001.5 1.5zm10.5-11.25h.008v.008h-.008V8.25zm.375 0a.375.375 0 11-.75 0 .375.375 0 01.75 0z" />
                </svg>
            </div>
        }
    </div>

    <!-- Thumbnail Strip -->
    @if (Images != null && Images.Count() > 1)
    {
        <div class="flex items-center gap-3 overflow-x-auto py-2 scrollbar-thin">
            @foreach (var img in Images)
            {
                var imgUrl = img.Url;
                var isActive = imgUrl == ActiveImageUrl;
                <button type="button" 
                        class="relative h-16 w-16 flex-shrink-0 overflow-hidden rounded-lg border-2 @(isActive ? "border-indigo-650 bg-white dark:bg-zinc-800" : "border-zinc-200 dark:border-zinc-800 hover:border-zinc-400 bg-zinc-50 dark:bg-zinc-900") transition-colors duration-150"
                        @onclick="() => SetActiveImage(imgUrl)">
                    <img src="@imgUrl" alt="Thumbnail" class="h-full w-full object-cover object-center" />
                </button>
            }
        </div>
    }
</div>

@code {
    private string? _activeImageUrl;

    [Parameter] public IEnumerable<ProductImageDto>? Images { get; set; }
    [Parameter] public string Class { get; set; } = string.Empty;

    private string? ActiveImageUrl
    {
        get
        {
            if (string.IsNullOrEmpty(_activeImageUrl) && Images != null && Images.Any())
            {
                var primary = Images.FirstOrDefault(i => i.IsPrimary) ?? Images.First();
                _activeImageUrl = primary.Url;
            }
            return _activeImageUrl;
        }
    }

    private void SetActiveImage(string url)
    {
        _activeImageUrl = url;
    }

    protected override void OnParametersSet()
    {
        // Reset active image if images change
        _activeImageUrl = null;
    }
}
