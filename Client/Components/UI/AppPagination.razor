@namespace Client.Components.UI

@if (TotalPages > 1)
{
    <nav class="flex items-center justify-between border-t border-zinc-200 dark:border-zinc-800 px-4 py-3 sm:px-6 @Class" aria-label="Pagination">
        <!-- Mobile View (Simple Next/Prev) -->
        <div class="flex flex-1 justify-between sm:hidden">
            <button @onclick="() => SelectPage(CurrentPage - 1)"
                    disabled="@(CurrentPage <= 1)"
                    class="relative inline-flex items-center rounded-md border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-800 px-4 py-2 text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-700 disabled:opacity-50 disabled:cursor-not-allowed">
                Previous
            </button>
            <button @onclick="() => SelectPage(CurrentPage + 1)"
                    disabled="@(CurrentPage >= TotalPages)"
                    class="relative ml-3 inline-flex items-center rounded-md border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-800 px-4 py-2 text-sm font-medium text-zinc-700 dark:text-zinc-300 hover:bg-zinc-50 dark:hover:bg-zinc-700 disabled:opacity-50 disabled:cursor-not-allowed">
                Next
            </button>
        </div>

        <!-- Desktop View (Page numbers) -->
        <div class="hidden sm:flex sm:flex-1 sm:items-center sm:justify-between">
            <div>
                <p class="text-sm text-zinc-750">
                    Showing page <span class="font-semibold text-zinc-900 dark:text-zinc-150">@CurrentPage</span> of <span class="font-semibold text-zinc-900 dark:text-zinc-150">@TotalPages</span>
                </p>
            </div>
            <div>
                <span class="isolate inline-flex -space-x-px rounded-md shadow-sm">
                    <!-- Prev -->
                    <button @onclick="() => SelectPage(CurrentPage - 1)"
                            disabled="@(CurrentPage <= 1)"
                            class="relative inline-flex items-center rounded-l-md px-2 py-2 text-zinc-400 ring-1 ring-inset ring-zinc-300 dark:ring-zinc-700 bg-white dark:bg-zinc-800 hover:bg-zinc-50 dark:hover:bg-zinc-700 focus:z-20 focus:outline-offset-0 disabled:opacity-50 disabled:cursor-not-allowed">
                        <span class="sr-only">Previous</span>
                        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M12.79 5.23a.75.75 0 01-.02 1.06L8.832 10l3.938 3.71a.75.75 0 11-1.04 1.08l-4.5-4.25a.75.75 0 010-1.08l4.5-4.25a.75.75 0 011.06.02z" clip-rule="evenodd" />
                        </svg>
                    </button>

                    <!-- Page Pills -->
                    @foreach (var pageNum in GetPageNumbers())
                    {
                        if (pageNum == -1)
                        {
                            <span class="relative inline-flex items-center px-4 py-2 text-sm font-semibold text-zinc-700 dark:text-zinc-300 ring-1 ring-inset ring-zinc-300 dark:ring-zinc-700 bg-white dark:bg-zinc-850 select-none">...</span>
                        }
                        else
                        {
                            var active = pageNum == CurrentPage;
                            <button @onclick="() => SelectPage(pageNum)"
                                    aria-current="@(active ? "page" : null)"
                                    class="@(active ? "relative z-10 inline-flex items-center bg-indigo-650 px-4 py-2 text-sm font-semibold text-white focus:z-20 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-indigo-600" : "relative inline-flex items-center px-4 py-2 text-sm font-semibold text-zinc-900 dark:text-zinc-150 ring-1 ring-inset ring-zinc-300 dark:ring-zinc-700 bg-white dark:bg-zinc-800 hover:bg-zinc-50 dark:hover:bg-zinc-700 focus:z-20 focus:outline-offset-0")">
                                @pageNum
                            </button>
                        }
                    }

                    <!-- Next -->
                    <button @onclick="() => SelectPage(CurrentPage + 1)"
                            disabled="@(CurrentPage >= TotalPages)"
                            class="relative inline-flex items-center rounded-r-md px-2 py-2 text-zinc-400 ring-1 ring-inset ring-zinc-300 dark:ring-zinc-700 bg-white dark:bg-zinc-800 hover:bg-zinc-50 dark:hover:bg-zinc-700 focus:z-20 focus:outline-offset-0 disabled:opacity-50 disabled:cursor-not-allowed">
                        <span class="sr-only">Next</span>
                        <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                            <path fill-rule="evenodd" d="M7.21 14.77a.75.75 0 01.02-1.06L11.168 10 7.23 6.29a.75.75 0 111.04-1.08l4.5 4.25a.75.75 0 010 1.08l-4.5 4.25a.75.75 0 01-1.06-.02z" clip-rule="evenodd" />
                        </svg>
                    </button>
                </span>
            </div>
        </div>
    </nav>
}

@code {
    [Parameter] public int CurrentPage { get; set; } = 1;
    [Parameter] public int TotalPages { get; set; } = 1;
    [Parameter] public EventCallback<int> PageChanged { get; set; }
    [Parameter] public string Class { get; set; } = string.Empty;

    private async Task SelectPage(int page)
    {
        if (page >= 1 && page <= TotalPages && page != CurrentPage)
        {
            CurrentPage = page;
            await PageChanged.InvokeAsync(page);
        }
    }

    private IEnumerable<int> GetPageNumbers()
    {
        var pages = new List<int>();
        var total = TotalPages;
        var current = CurrentPage;

        if (total <= 7)
        {
            for (var i = 1; i <= total; i++) pages.Add(i);
        }
        else
        {
            pages.Add(1);

            if (current > 4)
            {
                pages.Add(-1); // Dots
            }

            var start = Math.Max(2, current - 2);
            var end = Math.Min(total - 1, current + 2);

            // Adjust window if close to edges
            if (current <= 4)
            {
                end = 5;
            }
            if (current >= total - 3)
            {
                start = total - 4;
            }

            for (var i = start; i <= end; i++)
            {
                pages.Add(i);
            }

            if (current < total - 3)
            {
                pages.Add(-1); // Dots
            }

            pages.Add(total);
        }

        return pages;
    }
}
