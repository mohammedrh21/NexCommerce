@attribute [CascadingTypeParameter(nameof(TItem))]
@typeparam TItem
@namespace Client.Components.UI

<div class="overflow-x-auto shadow ring-1 ring-black/5 dark:ring-white/10 rounded-lg @Class">
    <table class="min-w-full divide-y divide-zinc-200 dark:divide-zinc-800 text-left text-sm text-zinc-500">
        <thead class="bg-zinc-50 dark:bg-zinc-900/50 text-xs font-semibold uppercase tracking-wider text-zinc-700 dark:text-zinc-300">
            <tr>
                @HeaderContent
            </tr>
        </thead>
        <tbody class="divide-y divide-zinc-200 dark:divide-zinc-800 bg-white dark:bg-zinc-900 text-zinc-900 dark:text-zinc-100">
            @if (IsLoading)
            {
                <tr>
                    <td colspan="100" class="px-6 py-10 text-center">
                        <div class="inline-flex items-center gap-2 text-indigo-650 dark:text-indigo-400">
                            <svg class="animate-spin h-5 w-5" fill="none" viewBox="0 0 24 24">
                                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                            </svg>
                            <span>Loading data...</span>
                        </div>
                    </td>
                </tr>
            }
            else if (Items == null || !Items.Any())
            {
                <tr>
                    <td colspan="100" class="px-6 py-12 text-center text-zinc-500 dark:text-zinc-400">
                        <div class="flex flex-col items-center justify-center gap-2">
                            <svg class="h-8 w-8 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
                            </svg>
                            <span>@EmptyMessage</span>
                        </div>
                    </td>
                </tr>
            }
            else
            {
                @foreach (var item in Items)
                {
                    <tr class="hover:bg-zinc-50 dark:hover:bg-zinc-850/50 transition-colors duration-150">
                        @RowTemplate(item)
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter] public IEnumerable<TItem>? Items { get; set; }
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public string EmptyMessage { get; set; } = "No items found.";
    [Parameter] public RenderFragment? HeaderContent { get; set; }
    [Parameter] public RenderFragment<TItem> RowTemplate { get; set; } = default!;
    [Parameter] public string Class { get; set; } = string.Empty;
}
