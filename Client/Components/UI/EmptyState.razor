@namespace Client.Components.UI

<div class="flex flex-col items-center justify-center text-center p-8 border border-dashed border-zinc-300 dark:border-zinc-800 rounded-xl bg-zinc-50/50 dark:bg-zinc-900/10 @Class">
    <!-- Illustration -->
    <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-400">
        @if (Illustration != null)
        {
            @Illustration
        }
        else
        {
            <svg class="h-8 w-8 text-zinc-400 dark:text-zinc-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 13.5h3.86a2.25 2.25 0 012.008 1.24l.885 1.77a2.25 2.25 0 002.007 1.24h1.98a2.25 2.25 0 002.007-1.24l.885-1.77a2.25 2.25 0 012.007-1.24h3.86m-18 0h18a2.25 2.25 0 012.25 2.25v4.5A2.25 2.25 0 0119.5 21h-15A2.25 2.25 0 013 18.75v-4.5A2.25 2.25 0 015.25 13.5zm3-7.5h7.5m-7.5 3h7.5M8.25 4.5h7.5" />
            </svg>
        }
    </div>

    <!-- Details -->
    <h3 class="mt-4 text-base font-semibold text-zinc-900 dark:text-zinc-100">@Title</h3>
    <p class="mt-1 text-sm text-zinc-550 dark:text-zinc-400 max-w-sm">@Description</p>

    <!-- Optional Action -->
    @if (!string.IsNullOrEmpty(ActionText) && OnAction.HasDelegate)
    {
        <div class="mt-6">
            <AppButton Variant="ButtonVariant.Primary" OnClick="HandleAction">
                @ActionText
            </AppButton>
        </div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "No items found";
    [Parameter] public string Description { get; set; } = "There are no records to display at this moment.";
    [Parameter] public string? ActionText { get; set; }
    [Parameter] public EventCallback OnAction { get; set; }
    [Parameter] public RenderFragment? Illustration { get; set; }
    [Parameter] public string Class { get; set; } = string.Empty;

    private async Task HandleAction()
    {
        await OnAction.InvokeAsync();
    }
}
