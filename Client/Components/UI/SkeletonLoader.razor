@namespace Client.Components.UI


<div class="animate-pulse @Class">
    @switch (Type)
    {
        case SkeletonType.Card:
            <div class="rounded-xl border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-4 shadow-sm">
                <div class="aspect-h-1 aspect-w-1 w-full overflow-hidden rounded-lg bg-zinc-200 dark:bg-zinc-800 h-48"></div>
                <div class="mt-4 space-y-3">
                    <div class="h-4 bg-zinc-200 dark:bg-zinc-800 rounded w-2/3"></div>
                    <div class="h-3 bg-zinc-200 dark:bg-zinc-800 rounded w-1/2"></div>
                    <div class="h-5 bg-zinc-200 dark:bg-zinc-800 rounded w-1/3 mt-2"></div>
                </div>
            </div>
            break;

        case SkeletonType.List:
            <div class="space-y-4">
                @for (int i = 0; i < Count; i++)
                {
                    <div class="flex items-center space-x-4 p-4 border border-zinc-200 dark:border-zinc-800 rounded-lg">
                        <div class="h-12 w-12 rounded bg-zinc-200 dark:bg-zinc-800 flex-shrink-0"></div>
                        <div class="flex-1 space-y-2 py-1">
                            <div class="h-4 bg-zinc-200 dark:bg-zinc-800 rounded w-3/4"></div>
                            <div class="h-3 bg-zinc-200 dark:bg-zinc-800 rounded w-1/2"></div>
                        </div>
                    </div>
                }
            </div>
            break;

        case SkeletonType.Table:
            <div class="space-y-3">
                @for (int i = 0; i < Count; i++)
                {
                    <div class="flex items-center space-x-4 py-3 border-b border-zinc-200 dark:border-zinc-800">
                        <div class="h-4 bg-zinc-200 dark:bg-zinc-800 rounded w-1/4"></div>
                        <div class="h-4 bg-zinc-200 dark:bg-zinc-800 rounded w-1/3"></div>
                        <div class="h-4 bg-zinc-200 dark:bg-zinc-800 rounded w-1/6"></div>
                        <div class="h-4 bg-zinc-200 dark:bg-zinc-800 rounded w-1/12"></div>
                    </div>
                }
            </div>
            break;

        case SkeletonType.Text:
        default:
            <div class="space-y-2.5">
                <div class="h-4 bg-zinc-200 dark:bg-zinc-800 rounded w-full"></div>
                <div class="h-4 bg-zinc-200 dark:bg-zinc-800 rounded w-5/6"></div>
                <div class="h-4 bg-zinc-200 dark:bg-zinc-800 rounded w-2/3"></div>
            </div>
            break;
    }
</div>

@code {
    public enum SkeletonType
    {
        Card,
        List,
        Table,
        Text
    }

    [Parameter] public SkeletonType Type { get; set; } = SkeletonType.Text;
    [Parameter] public int Count { get; set; } = 3;
    [Parameter] public string Class { get; set; } = string.Empty;
}
