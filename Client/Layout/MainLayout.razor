@inherits LayoutComponentBase
@namespace Client.Layout

<div class="min-h-screen flex flex-col bg-zinc-55 dark:bg-zinc-950 text-zinc-900 dark:text-zinc-150 transition-colors duration-200">
    <GlobalErrorBoundary>
        <!-- Navbar -->
        <Navbar />

        <!-- Main Body -->
        <main class="flex-1 w-full mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8">
            @Body
        </main>

        <!-- Footer -->
        <Footer />
        
        <!-- Toast Container -->
        <ToastContainer />
    </GlobalErrorBoundary>
</div>
