@inherits LayoutComponentBase
@namespace Client.Layout
@attribute [Authorize(Roles = "Vendor")]

<div class="flex h-screen bg-zinc-55 dark:bg-zinc-950 text-zinc-900 dark:text-zinc-150 transition-colors duration-200 overflow-hidden">
    <GlobalErrorBoundary>
        <!-- Sidebar -->
        <VendorSidebar />

        <!-- Main Body -->
        <div class="flex-1 flex flex-col overflow-hidden">
            <!-- Header -->
            <header class="h-16 border-b border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 flex items-center justify-between px-8 transition-colors duration-200">
                <div class="flex items-center gap-4">
                    <h2 class="text-base font-bold text-zinc-850 dark:text-zinc-100">Seller Dashboard</h2>
                </div>
                <div class="flex items-center gap-4">
                    <NotificationBell />
                    <div class="h-8 w-8 rounded-full bg-indigo-650 text-white font-bold flex items-center justify-center text-xs select-none shadow-sm">
                        VN
                    </div>
                </div>
            </header>

            <!-- Page content -->
            <main class="flex-1 p-8 overflow-y-auto">
                @Body
            </main>
        </div>

        <!-- Toast Container -->
        <ToastContainer />
    </GlobalErrorBoundary>
</div>
