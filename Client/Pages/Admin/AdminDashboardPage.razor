@page "/admin/dashboard"
@layout AdminLayout
@using Client.Models.Analytics
@using Client.Models.Vendors
@using Client.Models.Common
@using Client.Services.Http
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@namespace Client.Pages.Admin

<PageTitle>Admin Dashboard — NexCommerce</PageTitle>

<div class="space-y-8">
    <div>
        <h1 class="text-2xl font-bold text-zinc-900 dark:text-white">Dashboard</h1>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">Platform-wide overview and key metrics.</p>
    </div>

    @if (_isLoading)
    {
        <!-- Skeleton -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            @for (int i = 0; i < 8; i++)
            {
                <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5 animate-pulse">
                    <div class="h-3 bg-zinc-200 dark:bg-zinc-700 rounded w-2/3 mb-3"></div>
                    <div class="h-8 bg-zinc-200 dark:bg-zinc-700 rounded w-1/2 mb-2"></div>
                    <div class="h-3 bg-zinc-200 dark:bg-zinc-700 rounded w-1/3"></div>
                </div>
            }
        </div>
    }
    else if (_dashboard is not null)
    {
        var s = _dashboard.Stats;

        <!-- Stats Grid -->
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
            <!-- Total Revenue -->
            <div class="col-span-2 lg:col-span-1 bg-gradient-to-br from-indigo-600 to-indigo-700 dark:from-indigo-700 dark:to-indigo-800 rounded-2xl p-5 text-white shadow-lg shadow-indigo-200 dark:shadow-indigo-900/30">
                <p class="text-xs font-semibold text-indigo-200 uppercase tracking-wide">Total Revenue</p>
                <p class="text-3xl font-bold mt-2">@s.TotalRevenue.ToString("C0")</p>
                <p class="text-xs text-indigo-200 mt-1">
                    This month: <span class="text-white font-semibold">@s.RevenueThisMonth.ToString("C0")</span>
                </p>
            </div>

            <!-- Total Orders -->
            <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5 hover:shadow-md transition-shadow">
                <p class="text-xs font-medium text-zinc-500 dark:text-zinc-400 uppercase tracking-wide">Total Orders</p>
                <p class="text-3xl font-bold text-zinc-900 dark:text-white mt-2">@s.TotalOrders.ToString("N0")</p>
                <p class="text-xs text-amber-600 dark:text-amber-400 mt-1 font-medium">
                    @s.PendingOrders pending
                </p>
            </div>

            <!-- Total Users -->
            <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5 hover:shadow-md transition-shadow">
                <p class="text-xs font-medium text-zinc-500 dark:text-zinc-400 uppercase tracking-wide">Users</p>
                <p class="text-3xl font-bold text-zinc-900 dark:text-white mt-2">@s.TotalUsers.ToString("N0")</p>
                <p class="text-xs text-emerald-600 dark:text-emerald-400 mt-1 font-medium">
                    +@s.NewUsersThisMonth this month
                </p>
            </div>

            <!-- Vendors -->
            <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5 hover:shadow-md transition-shadow">
                <p class="text-xs font-medium text-zinc-500 dark:text-zinc-400 uppercase tracking-wide">Vendors</p>
                <p class="text-3xl font-bold text-zinc-900 dark:text-white mt-2">@s.TotalVendors.ToString("N0")</p>
                <a href="/admin/vendors" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline mt-1 inline-block font-medium">Manage →</a>
            </div>

            <!-- Products -->
            <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5 hover:shadow-md transition-shadow">
                <p class="text-xs font-medium text-zinc-500 dark:text-zinc-400 uppercase tracking-wide">Products</p>
                <p class="text-3xl font-bold text-zinc-900 dark:text-white mt-2">@s.TotalProducts.ToString("N0")</p>
                <a href="/admin/products" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline mt-1 inline-block font-medium">View all →</a>
            </div>
        </div>

        <!-- Revenue Chart (text-based bar chart) + Top Lists -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Revenue Chart -->
            <div class="lg:col-span-2 bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-6">
                <h2 class="text-sm font-semibold text-zinc-900 dark:text-white mb-5">Revenue — Last 6 Months</h2>
                @if (_dashboard.RevenueChart.Any())
                {
                    var maxRevenue = _dashboard.RevenueChart.Max(r => r.Revenue);
                    <div class="space-y-3">
                        @foreach (var point in _dashboard.RevenueChart)
                        {
                            var pct = maxRevenue > 0 ? (double)point.Revenue / (double)maxRevenue * 100 : 0;
                            <div class="flex items-center gap-3">
                                <span class="text-xs text-zinc-500 dark:text-zinc-400 w-10 flex-shrink-0 text-right">@point.Label</span>
                                <div class="flex-1 h-6 bg-zinc-100 dark:bg-zinc-800 rounded-lg overflow-hidden">
                                    <div class="h-full bg-indigo-500 dark:bg-indigo-600 rounded-lg transition-all duration-500 flex items-center justify-end pr-2"
                                         style="width: @pct.ToString("F0")%">
                                        @if (pct > 15)
                                        {
                                            <span class="text-[10px] font-semibold text-white">@point.Revenue.ToString("C0")</span>
                                        }
                                    </div>
                                </div>
                                <span class="text-xs font-semibold text-zinc-700 dark:text-zinc-300 w-16 flex-shrink-0">@point.Revenue.ToString("C0")</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-sm text-zinc-400 text-center py-8">No revenue data yet.</p>
                }
            </div>

            <!-- Top Vendors -->
            <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 overflow-hidden">
                <div class="px-5 py-4 border-b border-zinc-200 dark:border-zinc-800 flex items-center justify-between">
                    <h2 class="text-sm font-semibold text-zinc-900 dark:text-white">Top Vendors</h2>
                    <a href="/admin/vendors" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline font-medium">All</a>
                </div>
                @if (_dashboard.TopVendors.Any())
                {
                    <div class="divide-y divide-zinc-100 dark:divide-zinc-800">
                        @foreach (var v in _dashboard.TopVendors)
                        {
                            <div class="px-5 py-3.5 flex items-center justify-between gap-3">
                                <div class="min-w-0">
                                    <p class="text-sm font-medium text-zinc-900 dark:text-white truncate">@v.StoreName</p>
                                    <p class="text-xs text-zinc-500 dark:text-zinc-400">@v.TotalOrders orders</p>
                                </div>
                                <span class="text-sm font-bold text-zinc-900 dark:text-white flex-shrink-0">@v.Revenue.ToString("C0")</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-sm text-zinc-400 text-center py-8">No vendor data.</p>
                }
            </div>
        </div>

        <!-- Top Products + Pending Vendors -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
            <!-- Top Products -->
            <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 overflow-hidden">
                <div class="px-5 py-4 border-b border-zinc-200 dark:border-zinc-800">
                    <h2 class="text-sm font-semibold text-zinc-900 dark:text-white">Top Products</h2>
                </div>
                @if (_dashboard.TopProducts.Any())
                {
                    <div class="divide-y divide-zinc-100 dark:divide-zinc-800">
                        @foreach (var p in _dashboard.TopProducts)
                        {
                            <div class="px-5 py-3.5 flex items-center gap-3">
                                @if (!string.IsNullOrWhiteSpace(p.ImageUrl))
                                {
                                    <img src="@p.ImageUrl" alt="@p.ProductName" class="w-10 h-10 rounded-lg object-cover bg-zinc-100 dark:bg-zinc-800 flex-shrink-0" />
                                }
                                else
                                {
                                    <div class="w-10 h-10 rounded-lg bg-zinc-100 dark:bg-zinc-800 flex-shrink-0"></div>
                                }
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-medium text-zinc-900 dark:text-white truncate">@p.ProductName</p>
                                    <p class="text-xs text-zinc-400">@p.TotalSold units sold</p>
                                </div>
                                <span class="text-sm font-bold text-zinc-900 dark:text-white flex-shrink-0">@p.Revenue.ToString("C0")</span>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <p class="text-sm text-zinc-400 text-center py-8">No product data.</p>
                }
            </div>

            <!-- Pending Vendor Approvals -->
            <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 overflow-hidden">
                <div class="px-5 py-4 border-b border-zinc-200 dark:border-zinc-800 flex items-center justify-between">
                    <h2 class="text-sm font-semibold text-zinc-900 dark:text-white">Pending Approvals</h2>
                    @if (_pendingVendors is not null && _pendingVendors.Any())
                    {
                        <span class="px-2 py-0.5 rounded-full bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400 text-xs font-bold">
                            @_pendingVendors.Count()
                        </span>
                    }
                </div>
                @if (_isPendingLoading)
                {
                    <div class="p-5 animate-pulse space-y-3">
                        @for (int i = 0; i < 3; i++)
                        {
                            <div class="h-4 bg-zinc-200 dark:bg-zinc-700 rounded w-full"></div>
                        }
                    </div>
                }
                else if (_pendingVendors is null || !_pendingVendors.Any())
                {
                    <div class="p-8 text-center">
                        <div class="w-10 h-10 rounded-full bg-emerald-50 dark:bg-emerald-900/20 flex items-center justify-center mx-auto mb-2">
                            <svg class="w-5 h-5 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                            </svg>
                        </div>
                        <p class="text-sm text-zinc-500 dark:text-zinc-400">All caught up!</p>
                    </div>
                }
                else
                {
                    <div class="divide-y divide-zinc-100 dark:divide-zinc-800">
                        @foreach (var vendor in _pendingVendors)
                        {
                            <div class="px-5 py-3.5 flex items-center justify-between gap-3">
                                <div class="min-w-0">
                                    <p class="text-sm font-medium text-zinc-900 dark:text-white truncate">@vendor.StoreName</p>
                                    <p class="text-xs text-zinc-400 truncate">@vendor.OwnerName</p>
                                </div>
                                <div class="flex items-center gap-1.5 flex-shrink-0">
                                    <button @onclick="() => ApproveVendorAsync(vendor.Id, true)"
                                            class="px-2.5 py-1 bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-semibold rounded-lg transition-colors">
                                        Approve
                                    </button>
                                    <button @onclick="() => ApproveVendorAsync(vendor.Id, false)"
                                            class="px-2.5 py-1 bg-zinc-200 dark:bg-zinc-700 hover:bg-zinc-300 dark:hover:bg-zinc-600 text-zinc-700 dark:text-zinc-300 text-xs font-semibold rounded-lg transition-colors">
                                        Reject
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>
