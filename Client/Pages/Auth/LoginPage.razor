@page "/login"
@page "/auth/login"
@layout AuthLayout
@inherits Fluxor.Blazor.Web.Components.FluxorComponent

<PageTitle>Login - NexCommerce</PageTitle>

<div class="space-y-6">
    <div>
        <h2 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-white text-center">
            Sign in to your account
        </h2>
        <p class="mt-2 text-sm text-zinc-650 dark:text-zinc-400 text-center">
            Welcome back! Enter your details to access your dashboard.
        </p>
    </div>

    @if (!string.IsNullOrEmpty(AuthState.Value.Error))
    {
        <div class="rounded-lg bg-red-50 dark:bg-red-950/35 border border-red-200 dark:border-red-900/50 p-4">
            <div class="flex">
                <div class="flex-shrink-0 flex items-center">
                    <svg class="h-5 w-5 text-red-500" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="ml-3">
                    <h3 class="text-sm font-semibold text-red-800 dark:text-red-350">
                        Login failed
                    </h3>
                    <p class="mt-1 text-sm text-red-700 dark:text-red-400">
                        @AuthState.Value.Error
                    </p>
                </div>
            </div>
        </div>
    }

    <EditForm Model="@_loginModel" OnValidSubmit="HandleSubmit" class="space-y-5">
        <FluentValidationValidator />

        <div>
            <AppInput @bind-Value="_loginModel.Email"
                      Id="email"
                      Label="Email Address"
                      Type="email"
                      Placeholder="you@example.com"
                      Disabled="AuthState.Value.IsLoading"
                      ValidationExpression="() => _loginModel.Email">
                <Icon>
                    <svg class="h-5 w-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.206" />
                    </svg>
                </Icon>
            </AppInput>
        </div>

        <div>
            <AppInput @bind-Value="_loginModel.Password"
                      Id="password"
                      Label="Password"
                      Type="@(_showPassword ? "text" : "password")"
                      Placeholder="••••••••"
                      Disabled="AuthState.Value.IsLoading"
                      ValidationExpression="() => _loginModel.Password">
                <Icon>
                    <svg class="h-5 w-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                </Icon>
                <RightIcon>
                    <button type="button" @onclick="TogglePasswordVisibility" class="text-zinc-400 hover:text-zinc-650 dark:hover:text-zinc-300 focus:outline-none select-none flex items-center pr-1.5 h-full">
                        @if (_showPassword)
                        {
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18" />
                            </svg>
                        }
                        else
                        {
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        }
                    </button>
                </RightIcon>
            </AppInput>
        </div>

        <div class="flex items-center justify-between">
            <div class="flex items-center">
                <input id="remember-me" name="remember-me" type="checkbox" class="h-4 w-4 rounded border-zinc-350 dark:border-zinc-700 text-indigo-650 focus:ring-indigo-500 dark:focus:ring-indigo-450 bg-white dark:bg-zinc-800" />
                <label for="remember-me" class="ml-2 block text-xs text-zinc-750 dark:text-zinc-350 select-none">
                    Remember me
                </label>
            </div>

            <div class="text-xs">
                <a href="/forgot-password" class="font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 hover:underline">
                    Forgot your password?
                </a>
            </div>
        </div>

        <div>
            <AppButton Type="submit"
                       Variant="ButtonVariant.Primary"
                       Size="ButtonSize.Md"
                       IsLoading="AuthState.Value.IsLoading"
                       Disabled="AuthState.Value.IsLoading"
                       Class="w-full">
                Sign In
            </AppButton>
        </div>
    </EditForm>

    <div class="mt-6 text-center">
        <p class="text-xs text-zinc-650 dark:text-zinc-400">
            Don't have an account?
            <a href="/register" class="font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 hover:underline ml-1">
                Register here
            </a>
        </p>
    </div>
</div>
