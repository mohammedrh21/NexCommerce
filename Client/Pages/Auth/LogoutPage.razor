@page "/logout"
@page "/auth/logout"
@inject Fluxor.IDispatcher Dispatcher

<PageTitle>Logging out... - NexCommerce</PageTitle>

<div class="flex flex-col items-center justify-center min-h-[50vh] text-center p-4">
    <div class="animate-spin rounded-full h-12 w-12 border-t-2 border-b-2 border-indigo-600 dark:border-indigo-500 mb-4"></div>
    <h3 class="text-lg font-bold text-zinc-900 dark:text-white">Signing you out</h3>
    <p class="text-sm text-zinc-650 dark:text-zinc-400 mt-1">Please wait a moment while we clear your session.</p>
</div>

@code {
    protected override void OnInitialized()
    {
        base.OnInitialized();
        Dispatcher.Dispatch(new Client.State.Auth.LogoutAction());
    }
}
