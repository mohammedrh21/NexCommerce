@page "/register"
@page "/auth/register"
@layout AuthLayout
@inherits Fluxor.Blazor.Web.Components.FluxorComponent

<PageTitle>Register - NexCommerce</PageTitle>

<div class="space-y-6">
    <div>
        <h2 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-white text-center">
            Create your account
        </h2>
        <p class="mt-2 text-sm text-zinc-650 dark:text-zinc-400 text-center">
            Join NexCommerce today and start your journey.
        </p>
    </div>

    @if (!string.IsNullOrEmpty(AuthState.Value.Error))
    {
        <div class="rounded-lg bg-red-50 dark:bg-red-950/35 border border-red-200 dark:border-red-900/50 p-4">
            <div class="flex">
                <div class="flex-shrink-0 flex items-center">
                    <svg class="h-5 w-5 text-red-500" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                    </svg>
                </div>
                <div class="ml-3">
                    <h3 class="text-sm font-semibold text-red-800 dark:text-red-350">
                        Registration failed
                    </h3>
                    <p class="mt-1 text-sm text-red-700 dark:text-red-400">
                        @AuthState.Value.Error
                    </p>
                </div>
            </div>
        </div>
    }

    <EditForm Model="@_registerModel" OnValidSubmit="HandleSubmit" class="space-y-5">
        <FluentValidationValidator />

        <div>
            <AppInput @bind-Value="_registerModel.FullName"
                      Id="fullName"
                      Label="Full Name"
                      Type="text"
                      Placeholder="John Doe"
                      Disabled="AuthState.Value.IsLoading"
                      ValidationExpression="() => _registerModel.FullName">
                <Icon>
                    <svg class="h-5 w-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                </Icon>
            </AppInput>
        </div>

        <div>
            <AppInput @bind-Value="_registerModel.Email"
                      Id="email"
                      Label="Email Address"
                      Type="email"
                      Placeholder="you@example.com"
                      Disabled="AuthState.Value.IsLoading"
                      ValidationExpression="() => _registerModel.Email">
                <Icon>
                    <svg class="h-5 w-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 12a4 4 0 10-8 0 4 4 0 008 0zm0 0v1.5a2.5 2.5 0 005 0V12a9 9 0 10-9 9m4.5-1.206a8.959 8.959 0 01-4.5 1.206" />
                    </svg>
                </Icon>
            </AppInput>
        </div>

        <div>
            <AppInput @bind-Value="_registerModel.Password"
                      Id="password"
                      Label="Password"
                      Type="@(_showPassword ? "text" : "password")"
                      Placeholder="••••••••"
                      Disabled="AuthState.Value.IsLoading"
                      ValidationExpression="() => _registerModel.Password">
                <Icon>
                    <svg class="h-5 w-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                </Icon>
                <RightIcon>
                    <button type="button" @onclick="TogglePasswordVisibility" class="text-zinc-400 hover:text-zinc-650 dark:hover:text-zinc-300 focus:outline-none select-none flex items-center pr-1.5 h-full">
                        @if (_showPassword)
                        {
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l18 18" />
                            </svg>
                        }
                        else
                        {
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        }
                    </button>
                </RightIcon>
            </AppInput>
        </div>

        <div class="space-y-2">
            <label class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 select-none">
                I want to register as a:
            </label>
            <div class="grid grid-cols-2 gap-4">
                <!-- Customer Role Card -->
                <div @onclick='() => SelectRole("Customer")'
                     class="group relative flex flex-col justify-between rounded-xl border p-4 cursor-pointer focus:outline-none transition-all duration-200 select-none @(_registerModel.Role == "Customer" ? "border-indigo-600 dark:border-indigo-500 bg-indigo-50/20 dark:bg-indigo-950/10 shadow-sm ring-1 ring-indigo-650/25" : "border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 hover:border-zinc-350 dark:hover:border-zinc-755 hover:shadow-sm")">
                    <div class="flex items-center gap-3">
                        <div class="rounded-lg p-2 transition-colors duration-200 @(_registerModel.Role == "Customer" ? "bg-indigo-600 text-white" : "bg-zinc-100 dark:bg-zinc-800 text-zinc-600 dark:text-zinc-400 group-hover:bg-zinc-200 dark:group-hover:bg-zinc-750")">
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                            </svg>
                        </div>
                        <div>
                            <span class="block text-sm font-bold text-zinc-900 dark:text-white">Customer</span>
                            <span class="block text-[11px] text-zinc-650 dark:text-zinc-400 mt-0.5">I want to shop</span>
                        </div>
                    </div>
                </div>

                <!-- Vendor Role Card -->
                <div @onclick='() => SelectRole("Vendor")'
                     class="group relative flex flex-col justify-between rounded-xl border p-4 cursor-pointer focus:outline-none transition-all duration-200 select-none @(_registerModel.Role == "Vendor" ? "border-indigo-650 dark:border-indigo-500 bg-indigo-50/20 dark:bg-indigo-950/10 shadow-sm ring-1 ring-indigo-600/25" : "border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900/50 hover:border-zinc-350 dark:hover:border-zinc-755 hover:shadow-sm")">
                    <div class="flex items-center gap-3">
                        <div class="rounded-lg p-2 transition-colors duration-200 @(_registerModel.Role == "Vendor" ? "bg-indigo-600 text-white" : "bg-zinc-100 dark:bg-zinc-800 text-zinc-650 dark:text-zinc-400 group-hover:bg-zinc-200 dark:group-hover:bg-zinc-750")">
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                            </svg>
                        </div>
                        <div>
                            <span class="block text-sm font-bold text-zinc-900 dark:text-white">Vendor</span>
                            <span class="block text-[11px] text-zinc-650 dark:text-zinc-400 mt-0.5">I want to sell</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="text-xs text-red-650 dark:text-red-400 mt-1">
                <ValidationMessage For="() => _registerModel.Role" />
            </div>
        </div>

        <div>
            <AppButton Type="submit"
                       Variant="ButtonVariant.Primary"
                       Size="ButtonSize.Md"
                       IsLoading="AuthState.Value.IsLoading"
                       Disabled="AuthState.Value.IsLoading"
                       Class="w-full">
                Register
            </AppButton>
        </div>
    </EditForm>

    <div class="mt-6 text-center">
        <p class="text-xs text-zinc-650 dark:text-zinc-400">
            Already have an account?
            <a href="/login" class="font-medium text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 hover:underline ml-1">
                Sign in here
            </a>
        </p>
    </div>
</div>
