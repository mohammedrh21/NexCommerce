@page "/cart"
@layout MainLayout
@using Client.State.Cart
@using Client.Models.Cart
@using Client.Models.Coupons
@using Client.Services.Http
@using Client.State.Auth
@using Fluxor
@using Fluxor.Blazor.Web.Components
@inherits FluxorComponent
@namespace Client.Pages.Cart

<PageTitle>Shopping Cart — NexCommerce</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="flex items-center gap-3 mb-8">
        <h1 class="text-2xl font-bold text-zinc-900 dark:text-white">Shopping Cart</h1>
        @if (CartState.Value.TotalItems > 0)
        {
            <span class="inline-flex items-center justify-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-indigo-100 text-indigo-700 dark:bg-indigo-900/40 dark:text-indigo-300">
                @CartState.Value.TotalItems item@(CartState.Value.TotalItems == 1 ? "" : "s")
            </span>
        }
    </div>

    @if (!AuthState.Value.IsAuthenticated)
    {
        <div class="flex flex-col items-center justify-center py-24 text-center">
            <div class="w-20 h-20 rounded-full bg-indigo-50 dark:bg-indigo-900/20 flex items-center justify-center mb-6">
                <svg class="w-10 h-10 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
            </div>
            <h2 class="text-xl font-semibold text-zinc-900 dark:text-white mb-2">Sign in to view your cart</h2>
            <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-6">Cart items are saved to your account.</p>
            <a href="/login?returnUrl=/cart"
               class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition-colors">
                Sign In
            </a>
        </div>
    }
    else if (CartState.Value.IsLoading)
    {
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <div class="lg:col-span-2 space-y-4">
                @for (int i = 0; i < 3; i++)
                {
                    <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5 flex gap-4 animate-pulse">
                        <div class="w-20 h-20 rounded-xl bg-zinc-200 dark:bg-zinc-700 flex-shrink-0"></div>
                        <div class="flex-1 space-y-3 py-1">
                            <div class="h-4 bg-zinc-200 dark:bg-zinc-700 rounded w-2/3"></div>
                            <div class="h-3 bg-zinc-200 dark:bg-zinc-700 rounded w-1/3"></div>
                            <div class="h-4 bg-zinc-200 dark:bg-zinc-700 rounded w-1/4"></div>
                        </div>
                    </div>
                }
            </div>
            <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-6 h-64 animate-pulse"></div>
        </div>
    }
    else if (CartState.Value.Cart is null || !CartState.Value.Cart.Items.Any())
    {
        <div class="flex flex-col items-center justify-center py-24 text-center">
            <div class="w-20 h-20 rounded-full bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center mb-6">
                <svg class="w-10 h-10 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                </svg>
            </div>
            <h2 class="text-xl font-semibold text-zinc-900 dark:text-white mb-2">Your cart is empty</h2>
            <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-6">Discover great products and add them to your cart.</p>
            <a href="/products" class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold rounded-xl transition-colors">
                Browse Products
            </a>
        </div>
    }
    else
    {
        var cart = CartState.Value.Cart;
        var isUpdating = CartState.Value.IsUpdating;

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Cart Items -->
            <div class="lg:col-span-2 space-y-4">
                @foreach (var item in cart.Items)
                {
                    <div class="group bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5 flex gap-5 hover:border-indigo-200 dark:hover:border-indigo-800 transition-all duration-200">
                        <a href="/products/@item.ProductId" class="flex-shrink-0">
                            @if (!string.IsNullOrWhiteSpace(item.ProductImage))
                            {
                                <img src="@item.ProductImage" alt="@item.ProductName"
                                     class="w-20 h-20 rounded-xl object-cover bg-zinc-100 dark:bg-zinc-800 transition-transform duration-200 group-hover:scale-105"
                                     loading="lazy" />
                            }
                            else
                            {
                                <div class="w-20 h-20 rounded-xl bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center">
                                    <svg class="w-8 h-8 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14" />
                                    </svg>
                                </div>
                            }
                        </a>

                        <div class="flex-1 min-w-0">
                            <div class="flex items-start justify-between gap-3">
                                <div class="min-w-0">
                                    <a href="/products/@item.ProductId"
                                       class="font-semibold text-zinc-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400 truncate block transition-colors text-sm">
                                        @item.ProductName
                                    </a>
                                    <div class="flex flex-wrap gap-1.5 mt-1">
                                        @if (!string.IsNullOrEmpty(item.Size))
                                        {
                                            <span class="text-xs text-zinc-500 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800 px-2 py-0.5 rounded-md">@item.Size</span>
                                        }
                                        @if (!string.IsNullOrEmpty(item.Color))
                                        {
                                            <span class="text-xs text-zinc-500 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800 px-2 py-0.5 rounded-md">@item.Color</span>
                                        }
                                    </div>
                                    <p class="mt-1.5 text-sm font-semibold text-indigo-600 dark:text-indigo-400">@item.UnitPrice.ToString("C")</p>
                                </div>
                                <button @onclick="() => RemoveItem(item.Id)"
                                        disabled="@isUpdating"
                                        class="flex-shrink-0 p-1.5 text-zinc-400 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-lg transition-colors disabled:opacity-40"
                                        aria-label="Remove @item.ProductName">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                                    </svg>
                                </button>
                            </div>

                            <div class="flex items-center justify-between mt-4">
                                <!-- Qty stepper -->
                                <div class="flex items-center gap-1 bg-zinc-100 dark:bg-zinc-800 rounded-xl p-1">
                                    <button @onclick="() => Decrement(item)"
                                            disabled="@(isUpdating || item.Quantity <= 1)"
                                            class="w-7 h-7 rounded-lg flex items-center justify-center text-zinc-600 dark:text-zinc-400 hover:bg-white dark:hover:bg-zinc-700 hover:text-zinc-900 dark:hover:text-white disabled:opacity-40 transition-all"
                                            aria-label="Decrease quantity">
                                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M20 12H4" />
                                        </svg>
                                    </button>
                                    <span class="w-8 text-center text-sm font-bold text-zinc-900 dark:text-white">@item.Quantity</span>
                                    <button @onclick="() => Increment(item)"
                                            disabled="@(isUpdating || item.Quantity >= item.AvailableStock)"
                                            class="w-7 h-7 rounded-lg flex items-center justify-center text-zinc-600 dark:text-zinc-400 hover:bg-white dark:hover:bg-zinc-700 hover:text-zinc-900 dark:hover:text-white disabled:opacity-40 transition-all"
                                            aria-label="Increase quantity">
                                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" />
                                        </svg>
                                    </button>
                                </div>
                                <span class="text-base font-bold text-zinc-900 dark:text-white">@item.LineTotal.ToString("C")</span>
                            </div>

                            @if (item.AvailableStock < 5 && item.AvailableStock > 0)
                            {
                                <p class="mt-1.5 text-xs font-medium text-amber-600 dark:text-amber-400">
                                    Only @item.AvailableStock left!
                                </p>
                            }
                        </div>
                    </div>
                }

                <div class="flex justify-between items-center pt-2">
                    <a href="/products" class="text-sm text-indigo-600 dark:text-indigo-400 hover:underline font-medium">
                        ← Continue Shopping
                    </a>
                    <button @onclick="ClearCart" disabled="@isUpdating"
                            class="text-sm text-red-500 hover:text-red-700 dark:hover:text-red-400 font-medium flex items-center gap-1.5 py-2 px-3 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/10 transition-colors disabled:opacity-40">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                        Clear Cart
                    </button>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="lg:col-span-1">
                <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-6 sticky top-6">
                    <h2 class="text-base font-bold text-zinc-900 dark:text-white mb-5">Order Summary</h2>

                    <!-- Coupon -->
                    <div class="mb-5">
                        <label for="coupon-code" class="block text-xs font-semibold text-zinc-600 dark:text-zinc-400 uppercase tracking-wide mb-2">Promo Code</label>
                        <div class="flex gap-2">
                            <input id="coupon-code" type="text" @bind="_couponCode" @bind:event="oninput"
                                   placeholder="Enter code..."
                                   class="flex-1 px-3 py-2 rounded-xl border border-zinc-300 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 text-sm text-zinc-900 dark:text-white placeholder:text-zinc-400 focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                            <button @onclick="ApplyCouponAsync"
                                    disabled="@(_isApplyingCoupon || string.IsNullOrWhiteSpace(_couponCode))"
                                    class="px-3 py-2 bg-zinc-900 dark:bg-white text-white dark:text-zinc-900 text-sm font-bold rounded-xl hover:opacity-90 disabled:opacity-40 transition-all min-w-[64px]">
                                @if (_isApplyingCoupon)
                                {
                                    <span class="inline-block w-4 h-4 border-2 border-current border-t-transparent rounded-full animate-spin"></span>
                                }
                                else { <span>Apply</span> }
                            </button>
                        </div>
                        @if (!string.IsNullOrEmpty(_couponError))
                        {
                            <p class="mt-1.5 text-xs text-red-500">@_couponError</p>
                        }
                        @if (_appliedCoupon is not null)
                        {
                            <div class="mt-2 flex items-center gap-1.5 text-xs text-emerald-600 dark:text-emerald-400 font-medium">
                                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                </svg>
                                Code "@_appliedCoupon.Code" — save @_discount.ToString("C")
                                <button @onclick="RemoveCoupon" class="ml-auto text-zinc-400 hover:text-red-500 transition-colors">✕</button>
                            </div>
                        }
                    </div>

                    <div class="space-y-2.5 text-sm mb-5 pb-5 border-b border-zinc-100 dark:border-zinc-800">
                        <div class="flex justify-between text-zinc-600 dark:text-zinc-400">
                            <span>Subtotal</span>
                            <span class="font-semibold text-zinc-900 dark:text-white">@cart.SubTotal.ToString("C")</span>
                        </div>
                        @if (_discount > 0)
                        {
                            <div class="flex justify-between text-emerald-600 dark:text-emerald-400">
                                <span>Discount</span>
                                <span class="font-semibold">-@_discount.ToString("C")</span>
                            </div>
                        }
                        <div class="flex justify-between text-zinc-600 dark:text-zinc-400">
                            <span>Shipping</span>
                            <span class="text-emerald-600 dark:text-emerald-400 font-semibold">Free</span>
                        </div>
                    </div>

                    <div class="flex justify-between font-bold text-lg text-zinc-900 dark:text-white mb-6">
                        <span>Total</span>
                        <span>@((cart.SubTotal - _discount).ToString("C"))</span>
                    </div>

                    <a href="/checkout"
                       class="w-full flex items-center justify-center gap-2 px-6 py-3.5 bg-indigo-600 hover:bg-indigo-700 text-white font-bold rounded-xl transition-colors text-sm shadow-lg shadow-indigo-200 dark:shadow-indigo-900/30">
                        Proceed to Checkout
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                        </svg>
                    </a>

                    <div class="mt-4 flex items-center justify-center gap-1.5 text-xs text-zinc-400">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
                        </svg>
                        Secure SSL checkout
                    </div>
                </div>
            </div>
        </div>
    }
</div>
