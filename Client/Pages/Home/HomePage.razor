@page "/"
@inherits Fluxor.Blazor.Web.Components.FluxorComponent

<PageTitle>NexCommerce - Next-Gen Multi-Vendor Marketplace</PageTitle>

<div class="space-y-12 pb-16">
    <!-- Hero Section -->
    <div class="relative overflow-hidden rounded-3xl bg-zinc-900 dark:bg-zinc-950 px-8 py-16 sm:px-16 sm:py-24 shadow-2xl">
        <!-- Background Gradients -->
        <div class="absolute -top-40 -left-40 h-[600px] w-[600px] rounded-full bg-indigo-600/10 blur-3xl"></div>
        <div class="absolute -bottom-40 -right-40 h-[600px] w-[600px] rounded-full bg-violet-650/10 blur-3xl"></div>
        
        <div class="relative max-w-2xl mx-auto text-center space-y-6">
            <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-6xl bg-gradient-to-r from-zinc-100 via-indigo-100 to-indigo-300 bg-clip-text text-transparent leading-[1.15]">
                Welcome to NexCommerce
            </h1>
            <p class="text-lg text-zinc-300 leading-relaxed max-w-xl mx-auto">
                Discover a smart multi-vendor marketplace offering high-quality products from top-rated sellers around the world.
            </p>
            <div class="flex flex-wrap justify-center gap-4 pt-4">
                <a href="/products" class="inline-flex items-center justify-center rounded-xl bg-indigo-600 px-6 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-650/20 hover:bg-indigo-500 hover:shadow-indigo-500/30 transition-all duration-200">
                    Shop Products
                </a>
                <a href="/register?role=Vendor" class="inline-flex items-center justify-center rounded-xl bg-zinc-800 px-6 py-3 text-sm font-semibold text-zinc-100 hover:bg-zinc-700 hover:text-white transition-all duration-200 border border-zinc-700/80">
                    Sell on NexCommerce
                </a>
            </div>
        </div>
    </div>

    <!-- Category Grid Section -->
    <div class="space-y-6">
        <div class="flex items-center justify-between">
            <div>
                <h2 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-white">Shop by Category</h2>
                <p class="text-sm text-zinc-650 dark:text-zinc-400 mt-1">Explore our wide selection of departments</p>
            </div>
        </div>

        @if (_isLoadingCategories)
        {
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
                @for (int i = 0; i < 6; i++)
                {
                    <div class="h-28 rounded-xl bg-zinc-150 dark:bg-zinc-900/50 animate-pulse border border-zinc-200/50 dark:border-zinc-800/50"></div>
                }
            </div>
        }
        else if (!_categories.Any())
        {
            <div class="text-center py-10 bg-zinc-50 dark:bg-zinc-900/20 rounded-2xl border border-dashed border-zinc-200 dark:border-zinc-800">
                <p class="text-sm text-zinc-550 dark:text-zinc-400">No categories found</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
                @foreach (var category in _categories)
                {
                    <a href="/categories/@category.Id" 
                       class="group flex flex-col items-center justify-center p-6 rounded-2xl border border-zinc-200 dark:border-zinc-800/80 bg-white dark:bg-zinc-900 hover:border-indigo-555 hover:shadow-md transition-all duration-200 text-center">
                        <div class="h-10 w-10 rounded-lg bg-indigo-50 dark:bg-indigo-950/40 text-indigo-650 dark:text-indigo-400 flex items-center justify-center font-bold text-lg group-hover:scale-110 transition-transform duration-200">
                            @category.Name[0].ToString().ToUpper()
                        </div>
                        <span class="mt-3 text-sm font-bold text-zinc-900 dark:text-white group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors duration-150 line-clamp-1">
                            @category.Name
                        </span>
                        <span class="mt-1 text-[11px] text-zinc-550 dark:text-zinc-500">
                            @category.ProductCount products
                        </span>
                    </a>
                }
            </div>
        }
    </div>

    <!-- Personalized Section (Auth only) -->
    @if (AuthState.Value.IsAuthenticated && !_isLoadingPersonalized && _personalizedProducts.Any())
    {
        <div class="space-y-6">
            <div>
                <h2 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-white">Recommended For You</h2>
                <p class="text-sm text-zinc-650 dark:text-zinc-400 mt-1">Personalized items based on your shopping behavior</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                @foreach (var rec in _personalizedProducts)
                {
                    var productItem = MapToProductListItem(rec);
                    <ProductCard Product="@productItem"
                                 IsInWishlist="@_wishlistProductIds.Contains(productItem.Id)"
                                 OnAddToCart="HandleAddToCart"
                                 OnWishlistToggle="HandleWishlistToggle" />
                }
            </div>
        </div>
    }

    <!-- Trending Products Section -->
    <div class="space-y-6">
        <div class="flex items-center justify-between">
            <div>
                <h2 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-white">Trending Products</h2>
                <p class="text-sm text-zinc-650 dark:text-zinc-400 mt-1">Explore our most popular and fast-selling items</p>
            </div>
            <a href="/products" class="text-sm font-semibold text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 hover:underline">
                View all
            </a>
        </div>

        @if (_isLoadingTrending)
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                @for (int i = 0; i < 4; i++)
                {
                    <ProductCard IsLoading="true" />
                }
            </div>
        }
        else if (!_trendingProducts.Any())
        {
            <div class="text-center py-12 bg-zinc-50 dark:bg-zinc-900/20 rounded-2xl border border-dashed border-zinc-200 dark:border-zinc-800">
                <p class="text-sm text-zinc-500">No trending products available right now.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                @foreach (var rec in _trendingProducts)
                {
                    var productItem = MapToProductListItem(rec);
                    <ProductCard Product="@productItem"
                                 IsInWishlist="@_wishlistProductIds.Contains(productItem.Id)"
                                 OnAddToCart="HandleAddToCart"
                                 OnWishlistToggle="HandleWishlistToggle" />
                }
            </div>
        }
    </div>

    <!-- Featured Vendors Section -->
    <div class="space-y-6">
        <div class="flex items-center justify-between">
            <div>
                <h2 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-white">Featured Vendors</h2>
                <p class="text-sm text-zinc-650 dark:text-zinc-400 mt-1">Buy directly from your favorite local and global stores</p>
            </div>
            <a href="/vendors" class="text-sm font-semibold text-indigo-600 dark:text-indigo-400 hover:text-indigo-500 hover:underline">
                View all stores
            </a>
        </div>

        @if (_isLoadingVendors)
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                @for (int i = 0; i < 3; i++)
                {
                    <div class="h-44 rounded-2xl bg-zinc-150 dark:bg-zinc-900/50 animate-pulse border border-zinc-200/50 dark:border-zinc-800/50"></div>
                }
            </div>
        }
        else if (!_vendors.Any())
        {
            <div class="text-center py-12 bg-zinc-50 dark:bg-zinc-900/20 rounded-2xl border border-dashed border-zinc-200 dark:border-zinc-800">
                <p class="text-sm text-zinc-550 dark:text-zinc-400">No stores available right now.</p>
            </div>
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                @foreach (var vendor in _vendors)
                {
                    <VendorCard Vendor="@vendor" />
                }
            </div>
        }
    </div>
</div>
