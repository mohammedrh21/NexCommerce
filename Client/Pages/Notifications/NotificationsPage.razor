@page "/notifications"
@using Client.Models.Notifications
@using Client.Models.Common
@using Client.Services.Http
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@namespace Client.Pages.Notifications

<PageTitle>Notifications — NexCommerce</PageTitle>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
        <div>
            <h1 class="text-2xl font-bold text-zinc-900 dark:text-white">Notifications</h1>
            @if (_result is not null && _unreadCount > 0)
            {
                <p class="text-sm text-zinc-555 dark:text-zinc-400 mt-0.5">You have @_unreadCount unread notification@(_unreadCount == 1 ? "" : "s")</p>
            }
        </div>

        @if (_result is not null && _result.Data.Any(n => !n.IsRead))
        {
            <button @onclick="MarkAllAsReadAsync"
                    disabled="_isMarkingAll"
                    class="self-start sm:self-auto px-4 py-2 border border-zinc-200 dark:border-zinc-700 hover:bg-zinc-55 dark:hover:bg-zinc-800 text-zinc-700 dark:text-zinc-300 font-semibold rounded-xl text-sm transition-all flex items-center gap-1.5 disabled:opacity-50">
                @if (_isMarkingAll)
                {
                    <span class="inline-block w-4 h-4 border-2 border-current border-t-transparent rounded-full animate-spin"></span>
                }
                else
                {
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                }
                <span>Mark All as Read</span>
            </button>
        }
    </div>

    @if (_isLoading)
    {
        <div class="space-y-3">
            @for (int i = 0; i < 5; i++)
            {
                <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5 animate-pulse">
                    <div class="flex gap-4">
                        <div class="w-10 h-10 rounded-full bg-zinc-200 dark:bg-zinc-700 flex-shrink-0"></div>
                        <div class="flex-1 space-y-2 py-1">
                            <div class="h-3 bg-zinc-200 dark:bg-zinc-700 rounded w-1/4"></div>
                            <div class="h-4 bg-zinc-200 dark:bg-zinc-700 rounded w-full"></div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else if (_result is null || !_notifications.Any())
    {
        <div class="flex flex-col items-center justify-center py-20 text-center bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-8">
            <div class="w-16 h-16 rounded-full bg-zinc-50 dark:bg-zinc-800 flex items-center justify-center mb-4 text-zinc-400">
                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                </svg>
            </div>
            <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-2">All caught up!</h2>
            <p class="text-zinc-500 dark:text-zinc-400 text-sm max-w-xs">You don't have any notifications at the moment.</p>
        </div>
    }
    else
    {
        <div class="space-y-3">
            @foreach (var notif in _notifications)
            {
                <div class="relative bg-white dark:bg-zinc-900 rounded-2xl border @(notif.IsRead ? "border-zinc-200 dark:border-zinc-800" : "border-indigo-100 dark:border-indigo-900/50 bg-indigo-50/10 dark:bg-indigo-950/10 shadow-sm") p-4 sm:p-5 transition-all duration-200">
                    <!-- Unread Dot Indicator -->
                    @if (!notif.IsRead)
                    {
                        <span class="absolute top-5 right-5 w-2 h-2 bg-indigo-600 rounded-full"></span>
                    }

                    <div class="flex gap-4">
                        <!-- Icon -->
                        <div class="w-10 h-10 rounded-full flex-shrink-0 flex items-center justify-center @GetIconContainerClasses(notif.Type)">
                            @GetIconSvg(notif.Type)
                        </div>

                        <!-- Content -->
                        <div class="flex-1 min-w-0 pr-4 sm:pr-8">
                            <div class="flex items-center gap-2 mb-1.5 flex-wrap">
                                <span class="text-xs font-bold uppercase tracking-wider text-zinc-400">@GetTypeName(notif.Type)</span>
                                <span class="text-zinc-300 dark:text-zinc-700">·</span>
                                <time class="text-xs text-zinc-400 dark:text-zinc-500">
                                    @GetTimeAgo(notif.CreatedAt)
                                </time>
                            </div>
                            <p class="text-sm text-zinc-755 dark:text-zinc-200 @(notif.IsRead ? "font-normal" : "font-semibold") leading-relaxed">
                                @notif.Message
                            </p>
                        </div>

                        <!-- Mark Read Button -->
                        @if (!notif.IsRead)
                        {
                            <button @onclick="() => MarkAsReadAsync(notif)"
                                    title="Mark as Read"
                                    class="self-center p-1.5 hover:bg-zinc-55 dark:hover:bg-zinc-800 text-zinc-400 hover:text-indigo-650 dark:hover:text-indigo-400 rounded-lg transition-colors flex-shrink-0">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        @if (_result.TotalPages > 1)
        {
            <div class="mt-6 flex items-center justify-center gap-2">
                <button @onclick="() => ChangePage(_currentPage - 1)"
                        disabled="@(!_result.HasPreviousPage)"
                        class="px-3 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-700 text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:bg-zinc-55 dark:hover:bg-zinc-800 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                    ← Previous
                </button>
                <span class="text-sm text-zinc-500 dark:text-zinc-400 px-2">
                    Page @_currentPage of @_result.TotalPages
                </span>
                <button @onclick="() => ChangePage(_currentPage + 1)"
                        disabled="@(!_result.HasNextPage)"
                        class="px-3 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-700 text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:bg-zinc-55 dark:hover:bg-zinc-800 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                    Next →
                </button>
            </div>
        }
    }
</div>

@code {
    private string GetTypeName(NotificationType type) => type switch
    {
        NotificationType.OrderUpdate => "Order Update",
        NotificationType.NewOffer    => "Promotion",
        NotificationType.LowStock    => "Low Stock",
        NotificationType.Chat        => "Chat Message",
        _                            => "System"
    };

    private string GetIconContainerClasses(NotificationType type) => type switch
    {
        NotificationType.OrderUpdate => "bg-blue-50 dark:bg-blue-900/20 text-blue-600 dark:text-blue-400",
        NotificationType.NewOffer    => "bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600 dark:text-emerald-400",
        NotificationType.LowStock    => "bg-amber-50 dark:bg-amber-900/20 text-amber-600 dark:text-amber-400",
        NotificationType.Chat        => "bg-purple-50 dark:bg-purple-900/20 text-purple-600 dark:text-purple-400",
        _                            => "bg-zinc-50 dark:bg-zinc-800 text-zinc-500 dark:text-zinc-450"
    };

    private Microsoft.AspNetCore.Components.RenderFragment GetIconSvg(NotificationType type) => builder =>
    {
        switch (type)
        {
            case NotificationType.OrderUpdate:
                builder.AddMarkupContent(0, @"<svg class=""w-5 h-5"" fill=""none"" viewBox=""0 0 24 24"" stroke=""currentColor""><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""1.5"" d=""M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z""/></svg>");
                break;
            case NotificationType.NewOffer:
                builder.AddMarkupContent(0, @"<svg class=""w-5 h-5"" fill=""none"" viewBox=""0 0 24 24"" stroke=""currentColor""><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""1.5"" d=""M7 7h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z""/></svg>");
                break;
            case NotificationType.LowStock:
                builder.AddMarkupContent(0, @"<svg class=""w-5 h-5"" fill=""none"" viewBox=""0 0 24 24"" stroke=""currentColor""><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""1.5"" d=""M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z""/></svg>");
                break;
            case NotificationType.Chat:
                builder.AddMarkupContent(0, @"<svg class=""w-5 h-5"" fill=""none"" viewBox=""0 0 24 24"" stroke=""currentColor""><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""1.5"" d=""M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z""/></svg>");
                break;
            default:
                builder.AddMarkupContent(0, @"<svg class=""w-5 h-5"" fill=""none"" viewBox=""0 0 24 24"" stroke=""currentColor""><path stroke-linecap=""round"" stroke-linejoin=""round"" stroke-width=""1.5"" d=""M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z""/></svg>");
                break;
        }
    };

    private string GetTimeAgo(DateTime dt)
    {
        var span = DateTime.UtcNow - dt.ToUniversalTime();
        if (span.TotalMinutes < 1) return "Just now";
        if (span.TotalMinutes < 60) return $"{(int)span.TotalMinutes}m ago";
        if (span.TotalHours < 24) return $"{(int)span.TotalHours}h ago";
        return dt.ToString("MMM d");
    }
}
