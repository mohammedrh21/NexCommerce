@page "/orders"
@using Client.Models.Orders
@using Client.Models.Common
@using Client.Services.Http
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@namespace Client.Pages.Orders

<PageTitle>My Orders — NexCommerce</PageTitle>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center gap-3 mb-8">
        <h1 class="text-2xl font-bold text-zinc-900 dark:text-white">My Orders</h1>
        @if (_result is not null)
        {
            <span class="text-sm text-zinc-500 dark:text-zinc-400">(@_result.TotalCount total)</span>
        }
    </div>

    @if (_isLoading)
    {
        <div class="space-y-4">
            @for (int i = 0; i < 5; i++)
            {
                <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5 animate-pulse">
                    <div class="flex items-center justify-between">
                        <div class="space-y-2">
                            <div class="h-4 bg-zinc-200 dark:bg-zinc-700 rounded w-40"></div>
                            <div class="h-3 bg-zinc-200 dark:bg-zinc-700 rounded w-24"></div>
                        </div>
                        <div class="h-6 bg-zinc-200 dark:bg-zinc-700 rounded-full w-20"></div>
                    </div>
                </div>
            }
        </div>
    }
    else if (_result is null || !_result.Data.Any())
    {
        <div class="flex flex-col items-center justify-center py-20 text-center">
            <div class="w-16 h-16 rounded-full bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center mb-4">
                <svg class="w-8 h-8 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
            </div>
            <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-2">No orders yet</h2>
            <p class="text-zinc-500 dark:text-zinc-400 mb-6 text-sm">Start shopping to place your first order.</p>
            <a href="/products" class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white font-medium rounded-xl text-sm transition-colors">
                Browse Products
            </a>
        </div>
    }
    else
    {
        <div class="space-y-4">
            @foreach (var order in _result.Data)
            {
                <a href="/orders/@order.Id"
                   class="block bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5 hover:border-indigo-300 dark:hover:border-indigo-700 hover:shadow-sm transition-all duration-200 group">
                    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                        <div>
                            <div class="flex items-center gap-2 mb-1">
                                <span class="text-sm font-mono font-semibold text-zinc-900 dark:text-white">
                                    #@order.Id.ToString("N")[..8].ToUpper()
                                </span>
                                <span class="@GetStatusClasses(order.Status) inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold">
                                    @order.Status
                                </span>
                            </div>
                            <div class="flex items-center gap-3 text-xs text-zinc-500 dark:text-zinc-400">
                                <span>@order.CreatedAt.ToString("MMM d, yyyy")</span>
                                <span>·</span>
                                <span>@order.ItemCount item@(order.ItemCount == 1 ? "" : "s")</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-3">
                            <span class="text-base font-bold text-zinc-900 dark:text-white">@order.TotalAmount.ToString("C")</span>
                            <svg class="w-4 h-4 text-zinc-400 group-hover:text-indigo-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                            </svg>
                        </div>
                    </div>
                </a>
            }
        </div>

        <!-- Pagination -->
        @if (_result.TotalPages > 1)
        {
            <div class="mt-6 flex items-center justify-center gap-2">
                <button @onclick="() => ChangePage(_currentPage - 1)"
                        disabled="@(!_result.HasPreviousPage)"
                        class="px-3 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-700 text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:bg-zinc-50 dark:hover:bg-zinc-800 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                    ← Previous
                </button>
                <span class="text-sm text-zinc-500 dark:text-zinc-400 px-2">
                    Page @_currentPage of @_result.TotalPages
                </span>
                <button @onclick="() => ChangePage(_currentPage + 1)"
                        disabled="@(!_result.HasNextPage)"
                        class="px-3 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-700 text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:bg-zinc-50 dark:hover:bg-zinc-800 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                    Next →
                </button>
            </div>
        }
    }
</div>

@code {
    private string GetStatusClasses(OrderStatus status) => status switch
    {
        OrderStatus.Pending    => "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400",
        OrderStatus.Processing => "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400",
        OrderStatus.Shipped    => "bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-400",
        OrderStatus.Delivered  => "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400",
        OrderStatus.Cancelled  => "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400",
        _                      => "bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400"
    };
}
