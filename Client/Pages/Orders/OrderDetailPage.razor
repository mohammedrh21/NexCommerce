@page "/orders/{Id:guid}"
@using Client.Models.Orders
@using Client.Models.Common
@using Client.Services.Http
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@namespace Client.Pages.Orders

<PageTitle>Order Details — NexCommerce</PageTitle>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Back link -->
    <a href="/orders"
       class="inline-flex items-center gap-1.5 text-sm text-zinc-500 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors mb-6">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Back to Orders
    </a>

    @if (_isLoading)
    {
        <div class="space-y-4">
            <div class="h-8 bg-zinc-200 dark:bg-zinc-700 rounded-lg w-48 animate-pulse"></div>
            <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-6 animate-pulse space-y-4">
                @for (int i = 0; i < 4; i++)
                {
                    <div class="h-4 bg-zinc-200 dark:bg-zinc-700 rounded w-full"></div>
                }
            </div>
        </div>
    }
    else if (_errorMessage is not null)
    {
        <div class="flex flex-col items-center justify-center py-20 text-center">
            <div class="w-16 h-16 rounded-full bg-red-50 dark:bg-red-900/20 flex items-center justify-center mb-4">
                <svg class="w-8 h-8 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
                </svg>
            </div>
            <h2 class="text-lg font-semibold text-zinc-900 dark:text-white mb-2">Failed to load order</h2>
            <p class="text-zinc-500 dark:text-zinc-400 text-sm">@_errorMessage</p>
        </div>
    }
    else if (_order is not null)
    {
        <!-- Order Header -->
        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-6">
            <div>
                <h1 class="text-xl font-bold text-zinc-900 dark:text-white">
                    Order <span class="font-mono">#@_order.Id.ToString("N")[..8].ToUpper()</span>
                </h1>
                <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-0.5">
                    Placed on @_order.CreatedAt.ToString("MMMM d, yyyy 'at' h:mm tt")
                </p>
            </div>
            <span class="@GetStatusClasses(_order.Status) self-start sm:self-auto inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold">
                @_order.Status
            </span>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Left Column: Items + Timeline -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Order Items -->
                <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 overflow-hidden">
                    <div class="px-5 py-4 border-b border-zinc-200 dark:border-zinc-800">
                        <h2 class="text-sm font-semibold text-zinc-900 dark:text-white">
                            Items (@_order.Items.Count())
                        </h2>
                    </div>
                    <div class="divide-y divide-zinc-100 dark:divide-zinc-800">
                        @foreach (var item in _order.Items)
                        {
                            <div class="p-5 flex gap-4">
                                @if (!string.IsNullOrWhiteSpace(item.ProductImage))
                                {
                                    <img src="@item.ProductImage" alt="@item.ProductName"
                                         class="w-16 h-16 rounded-xl object-cover bg-zinc-100 dark:bg-zinc-800 flex-shrink-0" />
                                }
                                else
                                {
                                    <div class="w-16 h-16 rounded-xl bg-zinc-100 dark:bg-zinc-800 flex-shrink-0 flex items-center justify-center">
                                        <svg class="w-7 h-7 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                    </div>
                                }
                                <div class="flex-1 min-w-0">
                                    <a href="/products/@item.ProductId"
                                       class="text-sm font-semibold text-zinc-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">
                                        @item.ProductName
                                    </a>
                                    <div class="flex flex-wrap gap-2 mt-1">
                                        @if (!string.IsNullOrEmpty(item.Size))
                                        {
                                            <span class="text-xs text-zinc-500 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800 px-2 py-0.5 rounded">Size: @item.Size</span>
                                        }
                                        @if (!string.IsNullOrEmpty(item.Color))
                                        {
                                            <span class="text-xs text-zinc-500 dark:text-zinc-400 bg-zinc-100 dark:bg-zinc-800 px-2 py-0.5 rounded">Color: @item.Color</span>
                                        }
                                    </div>
                                    <div class="flex items-center justify-between mt-2">
                                        <span class="text-xs text-zinc-500 dark:text-zinc-400">
                                            Qty @item.Quantity × @item.Price.ToString("C")
                                        </span>
                                        <span class="text-sm font-bold text-zinc-900 dark:text-white">
                                            @item.LineTotal.ToString("C")
                                        </span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <!-- Status Timeline -->
                @if (_order.StatusHistory.Any())
                {
                    <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5">
                        <h2 class="text-sm font-semibold text-zinc-900 dark:text-white mb-5">Order Timeline</h2>
                        <ol class="relative border-l border-zinc-200 dark:border-zinc-700 ml-2 space-y-5">
                            @foreach (var entry in _order.StatusHistory.OrderByDescending(h => h.ChangedAt))
                            {
                                <li class="ml-4">
                                    <div class="absolute w-3 h-3 rounded-full -left-1.5 border-2 border-white dark:border-zinc-900 @GetTimelineDotColor(entry.Status)"></div>
                                    <div class="flex items-center justify-between">
                                        <span class="text-sm font-semibold text-zinc-800 dark:text-zinc-200">@entry.Status</span>
                                        <time class="text-xs text-zinc-400 dark:text-zinc-500">
                                            @entry.ChangedAt.ToString("MMM d, h:mm tt")
                                        </time>
                                    </div>
                                    @if (!string.IsNullOrEmpty(entry.Note))
                                    {
                                        <p class="text-xs text-zinc-500 dark:text-zinc-400 mt-0.5">@entry.Note</p>
                                    }
                                </li>
                            }
                        </ol>
                    </div>
                }

                <!-- Cancel Button -->
                @if (_order.Status == OrderStatus.Pending)
                {
                    <div class="bg-red-50 dark:bg-red-900/10 rounded-2xl border border-red-200 dark:border-red-900/30 p-5">
                        <h3 class="text-sm font-semibold text-red-700 dark:text-red-400 mb-1">Cancel Order</h3>
                        <p class="text-xs text-red-600 dark:text-red-400/80 mb-3">You can only cancel pending orders.</p>
                        <button @onclick="() => _showCancelConfirm = true"
                                class="px-4 py-2 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-xl transition-colors">
                            Cancel Order
                        </button>
                    </div>
                }
            </div>

            <!-- Right Column: Summary -->
            <div class="space-y-4">
                <!-- Price Summary -->
                <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5">
                    <h2 class="text-sm font-semibold text-zinc-900 dark:text-white mb-4">Payment Summary</h2>
                    <div class="space-y-2 text-sm">
                        <div class="flex justify-between text-zinc-600 dark:text-zinc-400">
                            <span>Subtotal</span>
                            <span class="font-medium text-zinc-900 dark:text-white">
                                @(_order.TotalAmount + (_order.DiscountAmount ?? 0)).ToString("C")
                            </span>
                        </div>
                        @if (_order.DiscountAmount is > 0)
                        {
                            <div class="flex justify-between text-emerald-600 dark:text-emerald-400">
                                <span>Discount @(!string.IsNullOrEmpty(_order.CouponCode) ? $"({_order.CouponCode})" : "")</span>
                                <span class="font-medium">-@_order.DiscountAmount?.ToString("C")</span>
                            </div>
                        }
                        <div class="flex justify-between text-zinc-600 dark:text-zinc-400">
                            <span>Shipping</span>
                            <span class="text-emerald-600 dark:text-emerald-400 font-medium">Free</span>
                        </div>
                        <div class="pt-2 border-t border-zinc-100 dark:border-zinc-800 flex justify-between font-bold text-zinc-900 dark:text-white">
                            <span>Total</span>
                            <span>@_order.TotalAmount.ToString("C")</span>
                        </div>
                    </div>
                </div>

                <!-- Shipping Address -->
                <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5">
                    <h2 class="text-sm font-semibold text-zinc-900 dark:text-white mb-3">Shipping Address</h2>
                    <p class="text-sm text-zinc-600 dark:text-zinc-400 whitespace-pre-line">@_order.ShippingAddress</p>
                </div>

                <!-- Payment Info -->
                @if (_order.Payment is not null)
                {
                    <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5">
                        <h2 class="text-sm font-semibold text-zinc-900 dark:text-white mb-3">Payment</h2>
                        <div class="space-y-1.5 text-sm text-zinc-600 dark:text-zinc-400">
                            <div class="flex justify-between">
                                <span>Status</span>
                                <span class="@GetPaymentStatusClasses(_order.Payment.Status) font-medium">@_order.Payment.Status</span>
                            </div>
                            @if (_order.Payment.PaidAt.HasValue)
                            {
                                <div class="flex justify-between">
                                    <span>Paid at</span>
                                    <span>@_order.Payment.PaidAt.Value.ToString("MMM d, yyyy")</span>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Cancel Confirm Modal -->
@if (_showCancelConfirm)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/40 backdrop-blur-sm">
        <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 shadow-2xl max-w-sm w-full p-6">
            <h3 class="text-base font-bold text-zinc-900 dark:text-white mb-2">Cancel Order?</h3>
            <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-4">This action cannot be undone.</p>
            <div class="mb-4">
                <label for="cancel-reason" class="block text-xs font-medium text-zinc-700 dark:text-zinc-300 mb-1">Reason (optional)</label>
                <input id="cancel-reason" type="text" @bind="_cancelReason" placeholder="Tell us why..."
                       class="w-full px-3 py-2 rounded-xl border border-zinc-300 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 text-sm text-zinc-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-red-500" />
            </div>
            <div class="flex gap-3">
                <button @onclick="() => _showCancelConfirm = false"
                        class="flex-1 px-4 py-2.5 border border-zinc-200 dark:border-zinc-700 text-sm font-medium text-zinc-700 dark:text-zinc-300 rounded-xl hover:bg-zinc-50 dark:hover:bg-zinc-800 transition-colors">
                    Keep Order
                </button>
                <button @onclick="CancelOrderAsync"
                        disabled="@_isCancelling"
                        class="flex-1 px-4 py-2.5 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-xl transition-colors disabled:opacity-60">
                    @if (_isCancelling)
                    {
                        <span class="inline-block w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
                    }
                    else
                    {
                        <span>Cancel Order</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    private string GetStatusClasses(OrderStatus status) => status switch
    {
        OrderStatus.Pending    => "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400",
        OrderStatus.Processing => "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400",
        OrderStatus.Shipped    => "bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-400",
        OrderStatus.Delivered  => "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400",
        OrderStatus.Cancelled  => "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400",
        _                      => "bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400"
    };

    private string GetTimelineDotColor(OrderStatus status) => status switch
    {
        OrderStatus.Pending    => "bg-amber-400",
        OrderStatus.Processing => "bg-blue-500",
        OrderStatus.Shipped    => "bg-indigo-500",
        OrderStatus.Delivered  => "bg-emerald-500",
        OrderStatus.Cancelled  => "bg-red-500",
        _                      => "bg-zinc-400"
    };

    private string GetPaymentStatusClasses(PaymentStatus status) => status switch
    {
        PaymentStatus.Succeeded => "text-emerald-600 dark:text-emerald-400",
        PaymentStatus.Failed    => "text-red-600 dark:text-red-400",
        PaymentStatus.Refunded  => "text-blue-600 dark:text-blue-400",
        _                       => "text-zinc-600 dark:text-zinc-400"
    };
}
