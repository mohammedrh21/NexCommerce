@page "/profile"
@using Client.Models.Users
@using Client.State.Auth
@using Fluxor
@using Fluxor.Blazor.Web.Components
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits FluxorComponent
@namespace Client.Pages.Profile

<PageTitle>Profile Settings — NexCommerce</PageTitle>

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <h1 class="text-2xl font-bold text-zinc-900 dark:text-white mb-8">Profile Settings</h1>

    @if (_isLoadingData)
    {
        <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-6 animate-pulse space-y-6">
            <div class="flex items-center gap-4">
                <div class="w-16 h-16 rounded-full bg-zinc-200 dark:bg-zinc-700"></div>
                <div class="space-y-2">
                    <div class="h-4 bg-zinc-200 dark:bg-zinc-700 rounded w-32"></div>
                    <div class="h-3 bg-zinc-200 dark:bg-zinc-700 rounded w-24"></div>
                </div>
            </div>
            <div class="space-y-3">
                <div class="h-4 bg-zinc-200 dark:bg-zinc-700 rounded w-full"></div>
                <div class="h-4 bg-zinc-200 dark:bg-zinc-700 rounded w-full"></div>
            </div>
        </div>
    }
    else if (_user is not null)
    {
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Left Card: Overview -->
            <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-6 flex flex-col items-center text-center">
                <div class="w-20 h-20 rounded-full bg-indigo-50 dark:bg-indigo-900/20 text-indigo-600 dark:text-indigo-400 flex items-center justify-center text-2xl font-bold mb-4">
                    @_user.FullName[0].ToString().ToUpper()
                </div>
                <h2 class="text-lg font-bold text-zinc-900 dark:text-white">@_user.FullName</h2>
                <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-4">@_user.Email</p>
                
                <div class="flex flex-wrap justify-center gap-1.5 mb-4">
                    @foreach (var role in _user.Roles)
                    {
                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold bg-zinc-100 dark:bg-zinc-800 text-zinc-800 dark:text-zinc-200">
                            @role
                        </span>
                    }
                </div>

                <div class="w-full border-t border-zinc-100 dark:border-zinc-800 pt-4 text-xs text-zinc-400 text-left space-y-2">
                    <div class="flex justify-between">
                        <span>Member Since</span>
                        <span class="font-medium text-zinc-700 dark:text-zinc-300">@_user.CreatedAt.ToString("MMMM d, yyyy")</span>
                    </div>
                    <div class="flex justify-between">
                        <span>Email Verification</span>
                        @if (_user.IsEmailVerified)
                        {
                            <span class="text-emerald-600 dark:text-emerald-400 font-medium">Verified</span>
                        }
                        else
                        {
                            <span class="text-amber-600 dark:text-amber-400 font-medium">Unverified</span>
                        }
                    </div>
                </div>
            </div>

            <!-- Right Card: Form -->
            <div class="md:col-span-2 bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-6">
                <h3 class="text-base font-bold text-zinc-900 dark:text-white mb-5 pb-3 border-b border-zinc-100 dark:border-zinc-800">
                    Account Details
                </h3>

                <form @submit:preventDefault="UpdateProfileAsync" class="space-y-4">
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="p-3 bg-red-550/10 border border-red-500/20 text-red-550 dark:text-red-400 text-sm rounded-xl">
                            @_errorMessage
                        </div>
                    }

                    <div>
                        <label for="profile-email" class="block text-sm font-medium text-zinc-500 dark:text-zinc-400 mb-1.5">
                            Email Address <span class="text-xs font-normal text-zinc-400">(Read-Only)</span>
                        </label>
                        <input id="profile-email"
                               type="email"
                               value="@_user.Email"
                               disabled
                               class="w-full px-3 py-2 rounded-xl border border-zinc-200 dark:border-zinc-850 bg-zinc-50 dark:bg-zinc-800/50 text-zinc-400 text-sm cursor-not-allowed" />
                    </div>

                    <div>
                        <label for="profile-name" class="block text-sm font-medium text-zinc-700 dark:text-zinc-300 mb-1.5">
                            Full Name <span class="text-red-500">*</span>
                        </label>
                        <input id="profile-name"
                               type="text"
                               @bind="_fullName"
                               placeholder="Enter your full name"
                               disabled="@_isSaving"
                               class="w-full px-3 py-2 rounded-xl border border-zinc-300 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-800 text-sm text-zinc-900 dark:text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 disabled:opacity-50 disabled:cursor-not-allowed" />
                        @if (_showValidation && string.IsNullOrWhiteSpace(_fullName))
                        {
                            <p class="mt-1.5 text-xs text-red-500">Full name is required.</p>
                        }
                    </div>

                    <div class="pt-4 flex justify-end">
                        <button type="submit"
                                disabled="@(_isSaving || string.IsNullOrWhiteSpace(_fullName))"
                                class="px-5 py-2.5 bg-zinc-850 hover:bg-zinc-800 dark:bg-white dark:text-zinc-900 dark:hover:bg-zinc-100 text-white font-semibold rounded-xl text-sm transition-all shadow-sm hover:shadow flex items-center gap-2 disabled:opacity-50 disabled:cursor-not-allowed">
                            @if (_isSaving)
                            {
                                <span class="inline-block w-4 h-4 border-2 border-current border-t-transparent rounded-full animate-spin"></span>
                                <span>Saving Changes...</span>
                            }
                            else
                            {
                                <span>Save Changes</span>
                            }
                        </button>
                    </div>
                </form>
            </div>
        </div>
    }
</div>
