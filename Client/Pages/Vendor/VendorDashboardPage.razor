@page "/vendor/dashboard"
@layout VendorLayout
@using Client.Models.Vendors
@using Client.Models.Products
@using Client.Models.Common
@using Client.Services.Http
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Vendor")]
@namespace Client.Pages.Vendor

<PageTitle>Vendor Dashboard — NexCommerce</PageTitle>

<div class="space-y-8">
    <!-- Welcome -->
    <div>
        <h1 class="text-2xl font-bold text-zinc-900 dark:text-white">
            Welcome back@(_profile is not null ? $", {_storeName}" : "")
        </h1>
        <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-1">Here's what's happening with your store today.</p>
    </div>

    @if (_isLoading)
    {
        <!-- Skeleton Stats -->
        <div class="grid grid-cols-2 lg:grid-cols-5 gap-4">
            @for (int i = 0; i < 5; i++)
            {
                <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5 animate-pulse">
                    <div class="h-3 bg-zinc-200 dark:bg-zinc-700 rounded w-2/3 mb-3"></div>
                    <div class="h-7 bg-zinc-200 dark:bg-zinc-700 rounded w-1/2"></div>
                </div>
            }
        </div>
    }
    else if (!(_profile?.IsApproved ?? false))
    {
        <!-- Pending Approval Banner -->
        <div class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 rounded-2xl p-6 flex gap-4">
            <div class="flex-shrink-0">
                <svg class="w-6 h-6 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <div>
                <h3 class="font-semibold text-amber-800 dark:text-amber-300">Account Pending Approval</h3>
                <p class="text-sm text-amber-700 dark:text-amber-400 mt-1">
                    Your vendor account is under review. You'll be notified once approved and can start listing products.
                </p>
            </div>
        </div>
    }
    else
    {
        <!-- Stats Cards -->
        <div class="grid grid-cols-2 lg:grid-cols-5 gap-4">
            <div class="col-span-1 bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5 hover:shadow-md transition-shadow">
                <p class="text-xs font-medium text-zinc-500 dark:text-zinc-400 uppercase tracking-wide">Products</p>
                <p class="text-3xl font-bold text-zinc-900 dark:text-white mt-2">@(_stats?.TotalProducts ?? 0)</p>
                <a href="/vendor/products" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline mt-2 inline-block">Manage →</a>
            </div>
            <div class="col-span-1 bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5 hover:shadow-md transition-shadow">
                <p class="text-xs font-medium text-zinc-500 dark:text-zinc-400 uppercase tracking-wide">Total Orders</p>
                <p class="text-3xl font-bold text-zinc-900 dark:text-white mt-2">@(_stats?.TotalOrders ?? 0)</p>
                <a href="/vendor/orders" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline mt-2 inline-block">View →</a>
            </div>
            <div class="col-span-1 bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5 hover:shadow-md transition-shadow">
                <p class="text-xs font-medium text-zinc-500 dark:text-zinc-400 uppercase tracking-wide">Revenue</p>
                <p class="text-2xl font-bold text-zinc-900 dark:text-white mt-2">@((_stats?.TotalRevenue ?? 0).ToString("C0"))</p>
            </div>
            <div class="col-span-1 bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-5 hover:shadow-md transition-shadow">
                <p class="text-xs font-medium text-zinc-500 dark:text-zinc-400 uppercase tracking-wide">Pending Orders</p>
                <p class="text-3xl font-bold text-amber-500 dark:text-amber-400 mt-2">@(_stats?.PendingOrders ?? 0)</p>
            </div>
            <div class="col-span-2 lg:col-span-1 bg-white dark:bg-zinc-900 rounded-2xl border @(_stats?.LowStockProducts > 0 ? "border-red-200 dark:border-red-900/50" : "border-zinc-200 dark:border-zinc-800") p-5 hover:shadow-md transition-shadow">
                <p class="text-xs font-medium text-zinc-500 dark:text-zinc-400 uppercase tracking-wide">Low Stock</p>
                <p class="text-3xl font-bold @(_stats?.LowStockProducts > 0 ? "text-red-500 dark:text-red-400" : "text-zinc-900 dark:text-white") mt-2">
                    @(_stats?.LowStockProducts ?? 0)
                </p>
                @if (_stats?.LowStockProducts > 0)
                {
                    <a href="/vendor/products?filter=lowstock" class="text-xs text-red-500 dark:text-red-400 hover:underline mt-2 inline-block">Review →</a>
                }
            </div>
        </div>

        <!-- Quick Actions + Recent Products -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <!-- Quick Actions -->
            <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-6">
                <h2 class="text-sm font-semibold text-zinc-900 dark:text-white mb-4">Quick Actions</h2>
                <div class="space-y-2">
                    <a href="/vendor/products/create"
                       class="flex items-center gap-3 p-3 rounded-xl hover:bg-indigo-50 dark:hover:bg-indigo-900/20 group transition-colors">
                        <div class="w-8 h-8 rounded-lg bg-indigo-100 dark:bg-indigo-900/40 flex items-center justify-center flex-shrink-0">
                            <svg class="w-4 h-4 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                            </svg>
                        </div>
                        <span class="text-sm font-medium text-zinc-700 dark:text-zinc-300 group-hover:text-indigo-600 dark:group-hover:text-indigo-400 transition-colors">Add New Product</span>
                    </a>
                    <a href="/vendor/orders"
                       class="flex items-center gap-3 p-3 rounded-xl hover:bg-zinc-50 dark:hover:bg-zinc-800 group transition-colors">
                        <div class="w-8 h-8 rounded-lg bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center flex-shrink-0">
                            <svg class="w-4 h-4 text-zinc-600 dark:text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                            </svg>
                        </div>
                        <span class="text-sm font-medium text-zinc-700 dark:text-zinc-300 group-hover:text-zinc-900 dark:group-hover:text-white transition-colors">Manage Orders</span>
                    </a>
                    <a href="/vendor/profile"
                       class="flex items-center gap-3 p-3 rounded-xl hover:bg-zinc-50 dark:hover:bg-zinc-800 group transition-colors">
                        <div class="w-8 h-8 rounded-lg bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center flex-shrink-0">
                            <svg class="w-4 h-4 text-zinc-600 dark:text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </div>
                        <span class="text-sm font-medium text-zinc-700 dark:text-zinc-300 group-hover:text-zinc-900 dark:group-hover:text-white transition-colors">Edit Store Profile</span>
                    </a>
                </div>
            </div>

            <!-- Recent Products -->
            <div class="lg:col-span-2 bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 overflow-hidden">
                <div class="px-5 py-4 border-b border-zinc-200 dark:border-zinc-800 flex items-center justify-between">
                    <h2 class="text-sm font-semibold text-zinc-900 dark:text-white">Recent Products</h2>
                    <a href="/vendor/products" class="text-xs text-indigo-600 dark:text-indigo-400 hover:underline font-medium">View All</a>
                </div>
                @if (_recentProducts is null || !_recentProducts.Any())
                {
                    <div class="p-8 text-center">
                        <p class="text-sm text-zinc-400">No products yet.</p>
                        <a href="/vendor/products/create" class="mt-3 text-sm text-indigo-600 dark:text-indigo-400 hover:underline inline-block">Add your first product →</a>
                    </div>
                }
                else
                {
                    <div class="divide-y divide-zinc-100 dark:divide-zinc-800">
                        @foreach (var p in _recentProducts.Take(5))
                        {
                            <div class="px-5 py-3.5 flex items-center gap-4 hover:bg-zinc-50 dark:hover:bg-zinc-800/50 transition-colors">
                                @if (!string.IsNullOrWhiteSpace(p.PrimaryImageUrl))
                                {
                                    <img src="@p.PrimaryImageUrl" alt="@p.Name" class="w-10 h-10 rounded-lg object-cover bg-zinc-100 dark:bg-zinc-800 flex-shrink-0" />
                                }
                                else
                                {
                                    <div class="w-10 h-10 rounded-lg bg-zinc-100 dark:bg-zinc-800 flex-shrink-0"></div>
                                }
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-medium text-zinc-900 dark:text-white truncate">@p.Name</p>
                                    <p class="text-xs text-zinc-500 dark:text-zinc-400">@p.CategoryName</p>
                                </div>
                                <div class="text-right flex-shrink-0">
                                    <p class="text-sm font-semibold text-zinc-900 dark:text-white">@p.Price.ToString("C")</p>
                                    <div class="flex items-center gap-1 justify-end mt-0.5">
                                        <svg class="w-3 h-3 text-amber-400 fill-amber-400" viewBox="0 0 20 20">
                                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                                        </svg>
                                        <span class="text-xs text-zinc-500 dark:text-zinc-400">@p.Rating.ToString("F1")</span>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>
