@page "/vendor/orders"
@layout VendorLayout
@using Client.Models.Orders
@using Client.Models.Common
@using Client.Services.Http
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Vendor")]
@namespace Client.Pages.Vendor

<PageTitle>Orders — NexCommerce Vendor</PageTitle>

<div class="space-y-6">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-zinc-900 dark:text-white">Orders</h1>
            @if (_result is not null)
            {
                <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-0.5">@_result.TotalCount total orders</p>
            }
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 overflow-hidden">
            @for (int i = 0; i < 7; i++)
            {
                <div class="p-5 border-b border-zinc-100 dark:border-zinc-800 last:border-0 animate-pulse flex items-center justify-between">
                    <div class="space-y-2">
                        <div class="h-4 bg-zinc-200 dark:bg-zinc-700 rounded w-32"></div>
                        <div class="h-3 bg-zinc-200 dark:bg-zinc-700 rounded w-24"></div>
                    </div>
                    <div class="h-6 bg-zinc-200 dark:bg-zinc-700 rounded-full w-20"></div>
                </div>
            }
        </div>
    }
    else if (_result is null || !_result.Data.Any())
    {
        <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-16 flex flex-col items-center text-center">
            <div class="w-16 h-16 rounded-2xl bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center mb-4">
                <svg class="w-8 h-8 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                </svg>
            </div>
            <h2 class="text-base font-semibold text-zinc-900 dark:text-white mb-1">No orders yet</h2>
            <p class="text-sm text-zinc-500 dark:text-zinc-400">Orders will appear here as customers start buying.</p>
        </div>
    }
    else
    {
        <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 overflow-hidden">
            <!-- Table Header -->
            <div class="grid grid-cols-12 px-5 py-3 bg-zinc-50 dark:bg-zinc-800/50 border-b border-zinc-200 dark:border-zinc-800 text-xs font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-wide">
                <div class="col-span-4">Order</div>
                <div class="col-span-3">Customer</div>
                <div class="col-span-2 text-center">Status</div>
                <div class="col-span-2 text-right">Total</div>
                <div class="col-span-1 text-right">Action</div>
            </div>

            <div class="divide-y divide-zinc-100 dark:divide-zinc-800">
                @foreach (var order in _result.Data)
                {
                    <div class="grid grid-cols-12 px-5 py-4 items-center hover:bg-zinc-50 dark:hover:bg-zinc-800/30 transition-colors">
                        <div class="col-span-4">
                            <p class="text-sm font-mono font-semibold text-zinc-900 dark:text-white">
                                #@order.Id.ToString("N")[..8].ToUpper()
                            </p>
                            <p class="text-xs text-zinc-400 mt-0.5">@order.CreatedAt.ToString("MMM d, yyyy")</p>
                        </div>
                        <div class="col-span-3">
                            <p class="text-sm text-zinc-700 dark:text-zinc-300 truncate">@order.CustomerName</p>
                            <p class="text-xs text-zinc-400">@order.ItemCount item@(order.ItemCount == 1 ? "" : "s")</p>
                        </div>
                        <div class="col-span-2 flex justify-center">
                            <span class="@GetStatusClasses(order.Status) inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-semibold">
                                @order.Status
                            </span>
                        </div>
                        <div class="col-span-2 text-right">
                            <p class="text-sm font-bold text-zinc-900 dark:text-white">@order.TotalAmount.ToString("C")</p>
                        </div>
                        <div class="col-span-1 flex justify-end">
                            @if (order.Status == Client.Models.Common.OrderStatus.Pending)
                            {
                                <button @onclick="() => MarkProcessingAsync(order.Id)"
                                        class="p-1.5 rounded-lg text-zinc-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 transition-colors"
                                        title="Mark as Processing">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                    </svg>
                                </button>
                            }
                        </div>
                    </div>
                }
            </div>
        </div>

        @if (_result.TotalPages > 1)
        {
            <div class="flex items-center justify-center gap-2">
                <button @onclick="() => ChangePage(_currentPage - 1)"
                        disabled="@(!_result.HasPreviousPage)"
                        class="px-3 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-700 text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:bg-zinc-50 dark:hover:bg-zinc-800 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                    ← Previous
                </button>
                <span class="text-sm text-zinc-500 dark:text-zinc-400 px-2">@_currentPage / @_result.TotalPages</span>
                <button @onclick="() => ChangePage(_currentPage + 1)"
                        disabled="@(!_result.HasNextPage)"
                        class="px-3 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-700 text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:bg-zinc-50 dark:hover:bg-zinc-800 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                    Next →
                </button>
            </div>
        }
    }
</div>

@code {
    private string GetStatusClasses(Client.Models.Common.OrderStatus status) => status switch
    {
        Client.Models.Common.OrderStatus.Pending    => "bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400",
        Client.Models.Common.OrderStatus.Processing => "bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400",
        Client.Models.Common.OrderStatus.Shipped    => "bg-indigo-100 text-indigo-700 dark:bg-indigo-900/30 dark:text-indigo-400",
        Client.Models.Common.OrderStatus.Delivered  => "bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400",
        Client.Models.Common.OrderStatus.Cancelled  => "bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400",
        _                                           => "bg-zinc-100 text-zinc-600 dark:bg-zinc-800 dark:text-zinc-400"
    };
}
