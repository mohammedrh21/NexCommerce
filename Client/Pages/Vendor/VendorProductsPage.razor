@page "/vendor/products"
@layout VendorLayout
@using Client.Models.Products
@using Client.Models.Common
@using Client.Services.Http
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Vendor")]
@namespace Client.Pages.Vendor

<PageTitle>My Products — NexCommerce Vendor</PageTitle>

<div class="space-y-6">
    <!-- Header -->
    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
        <div>
            <h1 class="text-2xl font-bold text-zinc-900 dark:text-white">Products</h1>
            @if (_result is not null)
            {
                <p class="text-sm text-zinc-500 dark:text-zinc-400 mt-0.5">@_result.TotalCount total</p>
            }
        </div>
        <a href="/vendor/products/create"
           id="btn-add-product"
           class="inline-flex items-center gap-2 px-4 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition-colors duration-200 self-start sm:self-auto">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Add Product
        </a>
    </div>

    <!-- Table / List -->
    @if (_isLoading)
    {
        <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 overflow-hidden">
            @for (int i = 0; i < 6; i++)
            {
                <div class="p-4 flex items-center gap-4 border-b border-zinc-100 dark:border-zinc-800 last:border-0 animate-pulse">
                    <div class="w-12 h-12 rounded-xl bg-zinc-200 dark:bg-zinc-700 flex-shrink-0"></div>
                    <div class="flex-1 space-y-2">
                        <div class="h-4 bg-zinc-200 dark:bg-zinc-700 rounded w-1/3"></div>
                        <div class="h-3 bg-zinc-200 dark:bg-zinc-700 rounded w-1/4"></div>
                    </div>
                    <div class="h-4 bg-zinc-200 dark:bg-zinc-700 rounded w-16"></div>
                </div>
            }
        </div>
    }
    else if (_result is null || !_result.Data.Any())
    {
        <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 p-16 flex flex-col items-center text-center">
            <div class="w-16 h-16 rounded-2xl bg-zinc-100 dark:bg-zinc-800 flex items-center justify-center mb-4">
                <svg class="w-8 h-8 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                </svg>
            </div>
            <h2 class="text-base font-semibold text-zinc-900 dark:text-white mb-1">No products yet</h2>
            <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-5">Start by adding your first product.</p>
            <a href="/vendor/products/create"
               class="px-5 py-2.5 bg-indigo-600 hover:bg-indigo-700 text-white text-sm font-semibold rounded-xl transition-colors">
                Add First Product
            </a>
        </div>
    }
    else
    {
        <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 overflow-hidden">
            <!-- Table header -->
            <div class="grid grid-cols-12 px-5 py-3 bg-zinc-50 dark:bg-zinc-800/50 border-b border-zinc-200 dark:border-zinc-800 text-xs font-semibold text-zinc-500 dark:text-zinc-400 uppercase tracking-wide">
                <div class="col-span-6">Product</div>
                <div class="col-span-2 text-right">Price</div>
                <div class="col-span-2 text-center">Rating</div>
                <div class="col-span-2 text-right">Actions</div>
            </div>

            <div class="divide-y divide-zinc-100 dark:divide-zinc-800">
                @foreach (var product in _result.Data)
                {
                    <div class="grid grid-cols-12 px-5 py-4 items-center hover:bg-zinc-50 dark:hover:bg-zinc-800/30 transition-colors group">
                        <!-- Product info -->
                        <div class="col-span-6 flex items-center gap-3 min-w-0">
                            @if (!string.IsNullOrWhiteSpace(product.PrimaryImageUrl))
                            {
                                <img src="@product.PrimaryImageUrl" alt="@product.Name"
                                     class="w-11 h-11 rounded-xl object-cover bg-zinc-100 dark:bg-zinc-800 flex-shrink-0" />
                            }
                            else
                            {
                                <div class="w-11 h-11 rounded-xl bg-zinc-100 dark:bg-zinc-800 flex-shrink-0 flex items-center justify-center">
                                    <svg class="w-5 h-5 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                </div>
                            }
                            <div class="min-w-0">
                                <p class="text-sm font-semibold text-zinc-900 dark:text-white truncate">@product.Name</p>
                                <p class="text-xs text-zinc-500 dark:text-zinc-400 truncate">@product.CategoryName</p>
                            </div>
                        </div>

                        <!-- Price -->
                        <div class="col-span-2 text-right">
                            <span class="text-sm font-semibold text-zinc-900 dark:text-white">@product.Price.ToString("C")</span>
                        </div>

                        <!-- Rating -->
                        <div class="col-span-2 flex items-center justify-center gap-1">
                            <svg class="w-3.5 h-3.5 text-amber-400 fill-amber-400" viewBox="0 0 20 20">
                                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                            </svg>
                            <span class="text-xs text-zinc-600 dark:text-zinc-400">@product.Rating.ToString("F1")</span>
                            <span class="text-xs text-zinc-400">(@product.ReviewCount)</span>
                        </div>

                        <!-- Actions -->
                        <div class="col-span-2 flex items-center justify-end gap-2">
                            <a href="/vendor/products/edit/@product.Id"
                               class="p-1.5 rounded-lg text-zinc-400 hover:text-indigo-600 dark:hover:text-indigo-400 hover:bg-indigo-50 dark:hover:bg-indigo-900/20 transition-colors"
                               aria-label="Edit @product.Name">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                            </a>
                            <button @onclick="() => ConfirmDelete(product)"
                                    class="p-1.5 rounded-lg text-zinc-400 hover:text-red-500 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
                                    aria-label="Delete @product.Name">
                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                            </button>
                        </div>
                    </div>
                }
            </div>
        </div>

        <!-- Pagination -->
        @if (_result.TotalPages > 1)
        {
            <div class="flex items-center justify-center gap-2">
                <button @onclick="() => ChangePage(_currentPage - 1)"
                        disabled="@(!_result.HasPreviousPage)"
                        class="px-3 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-700 text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:bg-zinc-50 dark:hover:bg-zinc-800 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                    ← Previous
                </button>
                <span class="text-sm text-zinc-500 dark:text-zinc-400 px-2">
                    @_currentPage / @_result.TotalPages
                </span>
                <button @onclick="() => ChangePage(_currentPage + 1)"
                        disabled="@(!_result.HasNextPage)"
                        class="px-3 py-1.5 rounded-lg border border-zinc-200 dark:border-zinc-700 text-sm font-medium text-zinc-600 dark:text-zinc-400 hover:bg-zinc-50 dark:hover:bg-zinc-800 disabled:opacity-40 disabled:cursor-not-allowed transition-colors">
                    Next →
                </button>
            </div>
        }
    }
</div>

<!-- Delete Confirm Modal -->
@if (_deleteTarget is not null)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/40 backdrop-blur-sm">
        <div class="bg-white dark:bg-zinc-900 rounded-2xl border border-zinc-200 dark:border-zinc-800 shadow-2xl max-w-sm w-full p-6">
            <h3 class="text-base font-bold text-zinc-900 dark:text-white mb-1">Delete Product?</h3>
            <p class="text-sm text-zinc-500 dark:text-zinc-400 mb-5">
                "<span class="font-medium text-zinc-700 dark:text-zinc-300">@_deleteTarget.Name</span>" will be permanently removed.
            </p>
            <div class="flex gap-3">
                <button @onclick="() => _deleteTarget = null"
                        class="flex-1 px-4 py-2.5 border border-zinc-200 dark:border-zinc-700 text-sm font-medium text-zinc-700 dark:text-zinc-300 rounded-xl hover:bg-zinc-50 dark:hover:bg-zinc-800 transition-colors">
                    Cancel
                </button>
                <button @onclick="DeleteProductAsync"
                        disabled="@_isDeleting"
                        class="flex-1 px-4 py-2.5 bg-red-600 hover:bg-red-700 text-white text-sm font-semibold rounded-xl transition-colors disabled:opacity-60">
                    @if (_isDeleting)
                    {
                        <span class="inline-block w-4 h-4 border-2 border-white border-t-transparent rounded-full animate-spin"></span>
                    }
                    else
                    {
                        <span>Delete</span>
                    }
                </button>
            </div>
        </div>
    </div>
}
