@page "/vendors/{Id:guid}"
@using Client.Components.Products
@using Client.Components.UI

<PageTitle>@(_translation?.StoreName ?? "Vendor Profile") | NexCommerce</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    @if (_isLoading)
    {
        <div class="animate-pulse space-y-8">
            <div class="h-32 bg-zinc-200 dark:bg-zinc-800 rounded-2xl w-full"></div>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                @for (var i = 0; i < 8; i++)
                {
                    <div class="h-80 bg-zinc-200 dark:bg-zinc-800 rounded-xl"></div>
                }
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <ErrorState Message="@_errorMessage" OnRetry="LoadVendorAndProductsAsync" />
    }
    else if (_vendor != null && _translation != null)
    {
        <nav class="flex mb-6 text-sm text-zinc-500 dark:text-zinc-400">
            <ol class="flex items-center space-x-2">
                <li>
                    <a href="/" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">Home</a>
                </li>
                <li>
                    <svg class="h-4 w-4 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </li>
                <li>
                    <a href="/vendors" class="hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors">Vendors</a>
                </li>
                <li>
                    <svg class="h-4 w-4 text-zinc-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </li>
                <li class="text-zinc-900 dark:text-white font-medium">@_translation.StoreName</li>
            </ol>
        </nav>

        <!-- Vendor Profile Header -->
        <div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-2xl p-6 sm:p-8 mb-8 shadow-sm flex flex-col sm:flex-row gap-6 items-start sm:items-center">
            <div class="flex-shrink-0 h-24 w-24 rounded-2xl bg-indigo-50 dark:bg-indigo-900/30 flex items-center justify-center text-4xl font-bold text-indigo-600 dark:text-indigo-400">
                @(_translation.StoreName.Length > 0 ? _translation.StoreName[0].ToString().ToUpper() : "?")
            </div>
            
            <div class="flex-1">
                <h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-white mb-2">
                    @_translation.StoreName
                </h1>
                @if (!string.IsNullOrWhiteSpace(_translation.Description))
                {
                    <p class="text-zinc-600 dark:text-zinc-300 max-w-3xl mb-4">
                        @_translation.Description
                    </p>
                }
                <div class="flex flex-wrap items-center gap-4 text-sm text-zinc-500 dark:text-zinc-400">
                    <span class="flex items-center gap-1">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9" />
                        </svg>
                        @_vendor.ProductCount Products
                    </span>
                    <span class="flex items-center gap-1">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
                        </svg>
                        Joined @_vendor.CreatedAt.ToString("MMM yyyy")
                    </span>
                </div>
            </div>
        </div>

        <div class="flex items-center justify-between mb-6">
            <h2 class="text-xl font-bold text-zinc-900 dark:text-white">Store Products</h2>
        </div>

        @if (_isLoadingProducts)
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 animate-pulse">
                @for (var i = 0; i < 8; i++)
                {
                    <div class="h-80 bg-zinc-200 dark:bg-zinc-800 rounded-xl"></div>
                }
            </div>
        }
        else if (_productsResult?.Data == null || !_productsResult.Data.Any())
        {
            <EmptyState Title="No products yet" 
                        Description="This vendor hasn't added any products to their store yet." 
                        Icon="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5m8.25 3v6.75m0 0l-3-3m3 3l3-3M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" />
        }
        else
        {
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 mb-8">
                @foreach (var product in _productsResult.Data)
                {
                    <ProductCard Product="@product" />
                }
            </div>

            @if (_productsResult.TotalPages > 1)
            {
                <div class="flex justify-center mt-12">
                    <AppPagination CurrentPage="@_productsResult.Page" 
                                   TotalPages="@_productsResult.TotalPages" 
                                   OnPageChanged="OnPageChanged" />
                </div>
            }
        }
    }
</div>
