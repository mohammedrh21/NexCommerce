@page "/vendors"
@using Client.Components.Vendors
@using Client.Components.UI

<PageTitle>Vendors | NexCommerce</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
        <h1 class="text-3xl font-bold tracking-tight text-zinc-900 dark:text-white">
            Our Vendors
        </h1>
        <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-400">
            Discover products from our amazing community of sellers.
        </p>
    </div>

    @if (_isLoading)
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 animate-pulse">
            @for (var i = 0; i < 8; i++)
            {
                <div class="h-48 bg-zinc-200 dark:bg-zinc-800 rounded-xl"></div>
            }
        </div>
    }
    else if (!string.IsNullOrEmpty(_errorMessage))
    {
        <ErrorState Message="@_errorMessage" OnRetry="LoadVendorsAsync" />
    }
    else if (_vendorsResult?.Data == null || !_vendorsResult.Data.Any())
    {
        <EmptyState Title="No vendors found" 
                    Description="There are currently no active vendors on the platform." 
                    Icon="M13.5 21v-7.5a.75.75 0 01.75-.75h3a.75.75 0 01.75.75V21m-4.5 0H2.36m11.14 0H18m0 0h3.64m-1.39 0V9.349m-16.5 11.65V9.35m0 0a3.001 3.001 0 003.75-.615A2.993 2.993 0 009.75 9.75c.896 0 1.7-.393 2.25-1.016a2.993 2.993 0 002.25 1.016c.896 0 1.7-.393 2.25-1.016a3.001 3.001 0 003.75.614m-16.5 0a3.004 3.004 0 01-.621-4.72L4.318 3.44A1.5 1.5 0 015.378 3h13.243a1.5 1.5 0 011.06.44l1.19 1.189a3 3 0 01-.621 4.72m-13.5 8.65h3.75a.75.75 0 00.75-.75V13.5a.75.75 0 00-.75-.75H6.75a.75.75 0 00-.75.75v3.75c0 .415.336.75.75.75z" />
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 mb-8">
            @foreach (var vendor in _vendorsResult.Data)
            {
                <VendorCard Vendor="@vendor" />
            }
        </div>

        @if (_vendorsResult.TotalPages > 1)
        {
            <div class="flex justify-center mt-12">
                <AppPagination CurrentPage="@_vendorsResult.Page" 
                               TotalPages="@_vendorsResult.TotalPages" 
                               OnPageChanged="OnPageChanged" />
            </div>
        }
    }
</div>
